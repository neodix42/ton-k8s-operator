#!/usr/bin/env bash
set -euo pipefail

RELEASE_NAME="${RELEASE_NAME:-ton-k8s-operator}"
OP_NAMESPACE="${OP_NAMESPACE:-ton-k8s-operator-system}"
CHART_DIR="${CHART_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
OP_VALUES_FILE="${OP_VALUES_FILE:-$CHART_DIR/operator-values.yaml}"
TON_VALUES_FILE="${TON_VALUES_FILE:-$CHART_DIR/tonnode-values.yaml}"
TON_POD_LABEL="${TON_POD_LABEL:-app.kubernetes.io/name=ton-node}"
TON_IMAGE_REPO="${TON_IMAGE_REPO:-ghcr.io/ton-blockchain/ton-docker-ctrl}"
TON_NAMESPACE="${TON_NAMESPACE:-default}"

AUTO_BAREMETAL_BOOTSTRAP="${AUTO_BAREMETAL_BOOTSTRAP:-true}"
FORCE_BAREMETAL_BOOTSTRAP="${FORCE_BAREMETAL_BOOTSTRAP:-false}"
SKIP_KEY_PREREQ_CHECK="${SKIP_KEY_PREREQ_CHECK:-false}"

LONGHORN_RELEASE_NAME="${LONGHORN_RELEASE_NAME:-longhorn}"
LONGHORN_NAMESPACE="${LONGHORN_NAMESPACE:-longhorn-system}"
LONGHORN_CHART="${LONGHORN_CHART:-longhorn/longhorn}"
LONGHORN_CHART_VERSION="${LONGHORN_CHART_VERSION:-1.10.0}"
LONGHORN_DEFAULT_REPLICA_COUNT="${LONGHORN_DEFAULT_REPLICA_COUNT:-3}"
ENCRYPTED_SC_NAME="${ENCRYPTED_SC_NAME:-encrypted-sc}"
LONGHORN_CRYPTO_SECRET_NAME="${LONGHORN_CRYPTO_SECRET_NAME:-longhorn-crypto}"
LOCALDEV_BASE_SC="${LOCALDEV_BASE_SC:-local-path}"
ALLOW_DESTRUCTIVE_LONGHORN_REPAIR="${ALLOW_DESTRUCTIVE_LONGHORN_REPAIR:-false}"
LONGHORN_NODE_SELECTOR="${LONGHORN_NODE_SELECTOR:-node.longhorn.io/create-default-disk=true}"

VAULT_RELEASE_NAME="${VAULT_RELEASE_NAME:-vault}"
VAULT_NAMESPACE="${VAULT_NAMESPACE:-vault}"
VAULT_CHART="${VAULT_CHART:-hashicorp/vault}"
VAULT_CHART_VERSION="${VAULT_CHART_VERSION:-0.30.0}"
VAULT_TRANSIT_KEY="${VAULT_TRANSIT_KEY:-ton-validator}"
VAULT_TON_POLICY_NAME="${VAULT_TON_POLICY_NAME:-tonnode-transit}"
VAULT_BOOTSTRAP_SECRET="${VAULT_BOOTSTRAP_SECRET:-ton-vault-bootstrap}"
VAULT_BOOTSTRAP_UNSEAL_KEY="${VAULT_BOOTSTRAP_UNSEAL_KEY:-}"
VAULT_BOOTSTRAP_ROOT_TOKEN="${VAULT_BOOTSTRAP_ROOT_TOKEN:-}"
TON_VAULT_CREDS_SECRET="${TON_VAULT_CREDS_SECRET:-ton-vault-creds}"
VAULT_ADDR_INTERNAL="${VAULT_ADDR_INTERNAL:-http://${VAULT_RELEASE_NAME}.${VAULT_NAMESPACE}.svc:8200}"
VAULT_TOKEN_PERIOD="${VAULT_TOKEN_PERIOD:-720h}"
NAMESPACE_DELETE_PROGRESS_TIMEOUT="${NAMESPACE_DELETE_PROGRESS_TIMEOUT:-60}"

usage() {
  cat <<'EOF'
Usage:
  kubeton <command>

Commands:
  install              Install or upgrade operator only (Helm upgrade --install with operator-values.yaml).
  bootstrap-baremetal  Prepare key prerequisites: Longhorn+Vault on bare-metal, local StorageClass+Vault on k3d.
  start                Start TON fleet (Helm upgrade with operator-values.yaml + tonnode-values.yaml).
  start <num>          Same as start, but overrides tonNode.replicas=<num>.
  add                  Add one TON replica to the existing TON StatefulSet.
  del                  Delete the tail TON pod replica (highest ordinal) with its PVC/PV/Longhorn volume.
  upgrade              Upgrade TON image: kubeton upgrade [tag] (default tag: latest).
  backup-keys          Trigger manual encrypted backup, export key bundles, restore TON replicas.
  restore-keys         Restore encrypted key bundles from backup dir, then restart TON replicas.
  stop                 Stop TON fleet (tonNode.enabled=false) after stop-time key backup.
  drop                 Stop TON fleet + delete TonNode resources + delete TON PVCs (with confirmation).
  uninstall            Stop/drop TON fleet + uninstall operator, Longhorn, and Vault (with confirmation; keeps TonNode CRD).
  purge                Full destructive cleanup: uninstall + delete TonNode CRD (separate to avoid accidental cluster-wide CRD removal).
  verify               Verify operator and TON resources (deploy/pods, tonnodes, sts/pods/pvc).
  status               Run "sync" and db size checks in each TON pod; print node/pod/sync/cell db/archive db.
  exec <cmd>           Run a command in each TON pod and print table with node/pod/exit code.

Environment overrides:
  RELEASE_NAME, OP_NAMESPACE, CHART_DIR, OP_VALUES_FILE, TON_VALUES_FILE, TON_POD_LABEL, TON_IMAGE_REPO
  TON_NAMESPACE
  AUTO_BAREMETAL_BOOTSTRAP, FORCE_BAREMETAL_BOOTSTRAP, SKIP_KEY_PREREQ_CHECK
  LONGHORN_RELEASE_NAME, LONGHORN_NAMESPACE, LONGHORN_CHART, LONGHORN_CHART_VERSION
  LONGHORN_DEFAULT_REPLICA_COUNT, ENCRYPTED_SC_NAME, LONGHORN_CRYPTO_SECRET_NAME
  LOCALDEV_BASE_SC, ALLOW_DESTRUCTIVE_LONGHORN_REPAIR, LONGHORN_NODE_SELECTOR
  VAULT_RELEASE_NAME, VAULT_NAMESPACE, VAULT_CHART, VAULT_CHART_VERSION
  VAULT_TRANSIT_KEY, VAULT_TON_POLICY_NAME, VAULT_BOOTSTRAP_SECRET
  VAULT_BOOTSTRAP_UNSEAL_KEY, VAULT_BOOTSTRAP_ROOT_TOKEN
  TON_VAULT_CREDS_SECRET, VAULT_ADDR_INTERNAL, VAULT_TOKEN_PERIOD
  NAMESPACE_DELETE_PROGRESS_TIMEOUT
  SKIP_STOP_KEY_BACKUP
EOF
}

require_bin() {
  local bin="$1"
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "Error: required command not found: $bin" >&2
    exit 1
  fi
}

sanitize_compact() {
  # Keep printable token/key characters only and remove all control/whitespace noise.
  printf '%s' "${1:-}" | tr -d '\000-\037\177' | tr -d '[:space:]'
}

trim_whitespace() {
  printf '%s' "${1:-}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

yaml_quote() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

parse_selector_pairs() {
  local selector="$1"
  local -n out_pairs="$2"
  local -a tokens=()
  local token key value

  out_pairs=()
  selector="$(trim_whitespace "$selector")"
  [[ -z "$selector" ]] && return 0

  IFS=',' read -r -a tokens <<<"$selector"
  for token in "${tokens[@]}"; do
    token="$(trim_whitespace "$token")"
    [[ -z "$token" ]] && continue
    if [[ "$token" != *=* ]]; then
      echo "Error: invalid node selector token '${token}', expected key=value." >&2
      return 1
    fi
    key="$(trim_whitespace "${token%%=*}")"
    value="$(trim_whitespace "${token#*=}")"
    if [[ -z "$key" || -z "$value" ]]; then
      echo "Error: invalid node selector token '${token}', empty key or value." >&2
      return 1
    fi
    out_pairs+=("${key}=${value}")
  done
}

write_yaml_map_from_pairs() {
  local -n pairs_ref="$1"
  local indent="${2:-2}"
  local padding pair key value

  padding="$(printf '%*s' "$indent" '')"
  for pair in "${pairs_ref[@]}"; do
    key="${pair%%=*}"
    value="${pair#*=}"
    printf '%s%s: %s\n' "$padding" "$(yaml_quote "$key")" "$(yaml_quote "$value")"
  done
}

selector_pairs_to_longhorn_setting() {
  local -n pairs_ref="$1"
  local out="" pair key value

  for pair in "${pairs_ref[@]}"; do
    key="${pair%%=*}"
    value="${pair#*=}"
    [[ -n "$out" ]] && out+=";"
    out+="${key}:${value}"
  done
  printf '%s' "$out"
}

build_longhorn_selector_values_file() {
  local selector="$1"
  local -a selector_pairs=()
  local setting_value values_file

  parse_selector_pairs "$selector" selector_pairs || return 1
  if [[ ${#selector_pairs[@]} -eq 0 ]]; then
    echo "Error: LONGHORN_NODE_SELECTOR is set but has no valid key=value pairs." >&2
    return 1
  fi

  setting_value="$(selector_pairs_to_longhorn_setting selector_pairs)"
  values_file="$(mktemp -t kubeton-longhorn-selector.XXXXXX.yaml)"
  {
    echo "global:"
    echo "  nodeSelector:"
    write_yaml_map_from_pairs selector_pairs 4
    echo "longhornManager:"
    echo "  nodeSelector:"
    write_yaml_map_from_pairs selector_pairs 4
    echo "longhornDriver:"
    echo "  nodeSelector:"
    write_yaml_map_from_pairs selector_pairs 4
    echo "longhornUI:"
    echo "  nodeSelector:"
    write_yaml_map_from_pairs selector_pairs 4
    echo "defaultSettings:"
    echo "  systemManagedComponentsNodeSelector: $(yaml_quote "$setting_value")"
  } >"$values_file"

  printf '%s' "$values_file"
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|True|yes|YES|Yes|y|Y) return 0 ;;
    *) return 1 ;;
  esac
}

confirm_or_exit() {
  local prompt="$1"
  local answer
  read -r -p "$prompt [y/N]: " answer
  case "${answer}" in
    y|Y|yes|YES) ;;
    *) echo "Cancelled."; exit 1 ;;
  esac
}

ensure_namespace() {
  local ns="$1"
  kubectl get namespace "$ns" >/dev/null 2>&1 || kubectl create namespace "$ns" >/dev/null
}

wait_namespace_gone() {
  local ns="$1"
  local timeout_seconds="${2:-180}"
  local deadline=$(( $(date +%s) + timeout_seconds ))
  local phase
  local force_attempts=0
  local max_force_attempts=4

  while kubectl get namespace "$ns" >/dev/null 2>&1; do
    phase="$(kubectl get namespace "$ns" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
    if (( $(date +%s) >= deadline )); then
      if [[ "$phase" == "Terminating" ]]; then
        if (( force_attempts >= max_force_attempts )); then
          echo "Error: namespace ${ns} is still Terminating after ${max_force_attempts} forced cleanup attempts." >&2
          return 1
        fi
        ((force_attempts+=1))
        echo "[localdev] Namespace ${ns} is stuck Terminating; clearing finalizers ..."
        kubectl patch namespace "$ns" --type=merge -p '{"spec":{"finalizers":[]}}' >/dev/null 2>&1 || true
        kubectl delete namespace "$ns" --ignore-not-found --wait=false >/dev/null 2>&1 || true
        deadline=$(( $(date +%s) + 60 ))
      else
        echo "Error: namespace ${ns} still exists after waiting ${timeout_seconds}s." >&2
        return 1
      fi
    fi
    sleep 2
  done
  return 0
}

ensure_namespace_not_terminating() {
  local ns="$1"
  local timeout_seconds="${2:-180}"
  local deadline=$(( $(date +%s) + timeout_seconds ))
  local phase
  local force_attempts=0
  local max_force_attempts=4

  while kubectl get namespace "$ns" >/dev/null 2>&1; do
    phase="$(kubectl get namespace "$ns" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
    if [[ "$phase" != "Terminating" ]]; then
      return 0
    fi
    if (( $(date +%s) >= deadline )); then
      if (( force_attempts >= max_force_attempts )); then
        echo "Error: namespace ${ns} remains Terminating after ${max_force_attempts} forced cleanup attempts." >&2
        return 1
      fi
      ((force_attempts+=1))
      echo "[localdev] Namespace ${ns} is stuck Terminating; clearing finalizers ..."
      kubectl patch namespace "$ns" --type=merge -p '{"spec":{"finalizers":[]}}' >/dev/null 2>&1 || true
      kubectl delete namespace "$ns" --ignore-not-found --wait=false >/dev/null 2>&1 || true
      deadline=$(( $(date +%s) + 60 ))
    fi
    sleep 2
  done

  return 0
}

cluster_is_baremetal() {
  local provider_ids compact
  provider_ids="$(kubectl get nodes -o jsonpath='{range .items[*]}{.spec.providerID}{"\n"}{end}')"
  compact="$(printf '%s' "$provider_ids" | tr -d '[:space:]')"
  [[ -z "$compact" ]]
}

cluster_is_k3d() {
  local context node nonempty=0
  context="$(kubectl config current-context 2>/dev/null || true)"
  if [[ "$context" == k3d-* ]]; then
    return 0
  fi

  while IFS= read -r node; do
    [[ -z "$node" ]] && continue
    nonempty=1
    [[ "$node" == k3d-* ]] || return 1
  done < <(kubectl get nodes -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null || true)

  [[ "$nonempty" -eq 1 ]]
}

should_bootstrap_baremetal() {
  if ! is_true "$AUTO_BAREMETAL_BOOTSTRAP"; then
    return 1
  fi
  if is_true "$FORCE_BAREMETAL_BOOTSTRAP"; then
    return 0
  fi
  if cluster_is_baremetal || cluster_is_k3d; then
    return 0
  fi
  return 1
}

resolve_localdev_storage_class() {
  local default_sc first_sc

  if [[ -n "$LOCALDEV_BASE_SC" ]] && kubectl get storageclass "$LOCALDEV_BASE_SC" >/dev/null 2>&1; then
    printf '%s\n' "$LOCALDEV_BASE_SC"
    return 0
  fi

  if kubectl get storageclass local-path >/dev/null 2>&1; then
    printf '%s\n' "local-path"
    return 0
  fi

  default_sc="$(kubectl get storageclass -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.metadata.annotations.storageclass\.kubernetes\.io/is-default-class}{"\n"}{end}' 2>/dev/null | awk '$2=="true"{print $1; exit}')"
  if [[ -n "$default_sc" ]]; then
    printf '%s\n' "$default_sc"
    return 0
  fi

  first_sc="$(kubectl get storageclass -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)"
  if [[ -n "$first_sc" ]]; then
    printf '%s\n' "$first_sc"
    return 0
  fi

  echo "Error: no StorageClass found; local dev bootstrap requires at least one StorageClass." >&2
  exit 1
}

ensure_helm_repo() {
  local name="$1"
  local url="$2"
  helm repo add "$name" "$url" --force-update >/dev/null
}

cleanup_longhorn_webhook_configs() {
  kubectl get validatingwebhookconfiguration,mutatingwebhookconfiguration -o name 2>/dev/null \
    | grep -Ei 'longhorn' \
    | xargs -r kubectl delete --ignore-not-found >/dev/null 2>&1 || true
}

clear_longhorn_namespace_resource_finalizers() {
  local resource
  for resource in $(kubectl api-resources --api-group=longhorn.io -o name 2>/dev/null || true); do
    kubectl -n "$LONGHORN_NAMESPACE" get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl -n "$LONGHORN_NAMESPACE" patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
  done
}

force_finalize_namespace() {
  local ns="$1"

  kubectl patch namespace "$ns" --type=json -p='[{"op":"replace","path":"/spec/finalizers","value":[]}]' >/dev/null 2>&1 || true
  kubectl patch namespace "$ns" --type=merge -p '{"spec":{"finalizers":[]}}' >/dev/null 2>&1 || true

  if command -v jq >/dev/null 2>&1; then
    kubectl get ns "$ns" -o json 2>/dev/null \
      | jq '.spec.finalizers=[]' \
      | kubectl replace --raw "/api/v1/namespaces/${ns}/finalize" -f - >/dev/null 2>&1 || true
  fi

  kubectl delete namespace "$ns" --ignore-not-found --wait=false >/dev/null 2>&1 || true
}

recover_stuck_longhorn_namespace() {
  local phase
  if ! kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi

  phase="$(kubectl get namespace "$LONGHORN_NAMESPACE" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
  if [[ "$phase" != "Terminating" ]]; then
    return 0
  fi

  echo "[baremetal] Namespace ${LONGHORN_NAMESPACE} is Terminating; cleaning stale Longhorn webhooks/finalizers ..."
  cleanup_longhorn_webhook_configs
  clear_longhorn_namespace_resource_finalizers
  force_finalize_namespace "$LONGHORN_NAMESPACE"
  wait_namespace_gone "$LONGHORN_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT" || true
}

cleanup_vault_force() {
  echo "[uninstall] Forcing Vault cleanup ..."

  if ! kubectl get namespace "$VAULT_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi

  # Ensure workload references are gone so pvc-protection can clear.
  kubectl -n "$VAULT_NAMESPACE" delete statefulset vault --ignore-not-found --wait=false >/dev/null 2>&1 || true
  kubectl -n "$VAULT_NAMESPACE" delete pod --all --ignore-not-found --grace-period=0 --force >/dev/null 2>&1 || true

  local pvc pv
  for pvc in $(kubectl -n "$VAULT_NAMESPACE" get pvc -o name 2>/dev/null || true); do
    kubectl -n "$VAULT_NAMESPACE" patch "$pvc" --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    pv="$(kubectl -n "$VAULT_NAMESPACE" get "$pvc" -o jsonpath='{.spec.volumeName}' 2>/dev/null || true)"
    if [[ -n "$pv" ]]; then
      kubectl patch "pv/${pv}" --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    fi
  done
  kubectl -n "$VAULT_NAMESPACE" delete pvc --all --ignore-not-found --wait=false >/dev/null 2>&1 || true

  local resource
  for resource in $(kubectl api-resources --verbs=list --namespaced -o name 2>/dev/null || true); do
    kubectl -n "$VAULT_NAMESPACE" get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl -n "$VAULT_NAMESPACE" patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    kubectl -n "$VAULT_NAMESPACE" delete "$resource" --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  force_finalize_namespace "$VAULT_NAMESPACE"
  wait_namespace_gone "$VAULT_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT" || true
}

recover_stuck_vault_namespace() {
  local phase
  if ! kubectl get namespace "$VAULT_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi

  phase="$(kubectl get namespace "$VAULT_NAMESPACE" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
  if [[ "$phase" != "Terminating" ]]; then
    return 0
  fi

  echo "[baremetal] Namespace ${VAULT_NAMESPACE} is Terminating; cleaning stuck Vault pods/PVC/finalizers ..."
  cleanup_vault_force
}

delete_namespace_with_progress() {
  local ns="$1"
  local timeout_seconds="${2:-$NAMESPACE_DELETE_PROGRESS_TIMEOUT}"
  local start_ts now_ts elapsed phase pods
  local force_attempts=0
  local max_force_attempts=3

  if ! kubectl get namespace "$ns" >/dev/null 2>&1; then
    echo "[uninstall] Namespace ${ns} already absent."
    return 0
  fi

  echo "[uninstall] Deleting namespace ${ns} ..."
  kubectl delete namespace "$ns" --ignore-not-found --wait=false >/dev/null 2>&1 || true

  start_ts="$(date +%s)"
  while kubectl get namespace "$ns" >/dev/null 2>&1; do
    now_ts="$(date +%s)"
    elapsed=$((now_ts - start_ts))
    phase="$(kubectl get namespace "$ns" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
    pods="$(kubectl -n "$ns" get pods --no-headers 2>/dev/null | awk 'NF{c++} END{print c+0}')"
    [[ -z "$pods" ]] && pods="0"
    echo "[progress] namespace ${ns}: phase=${phase:-unknown}, pods=${pods} (elapsed ${elapsed}s)"

    if (( elapsed >= timeout_seconds )); then
      if (( force_attempts >= max_force_attempts )); then
        echo "Warning: namespace ${ns} still exists after ${max_force_attempts} forced cleanup attempts; continuing uninstall." >&2
        return 0
      fi
      ((force_attempts+=1))
      echo "Warning: namespace ${ns} still exists after ${timeout_seconds}s; forcing cleanup attempt." >&2
      if [[ "$ns" == "$LONGHORN_NAMESPACE" ]]; then
        recover_stuck_longhorn_namespace || true
      elif [[ "$ns" == "$VAULT_NAMESPACE" ]]; then
        recover_stuck_vault_namespace || true
      else
        kubectl patch namespace "$ns" --type=merge -p '{"spec":{"finalizers":[]}}' >/dev/null 2>&1 || true
        kubectl delete namespace "$ns" --ignore-not-found --wait=false >/dev/null 2>&1 || true
      fi
      start_ts="$(date +%s)"
    fi
    sleep 10
  done

  echo "[uninstall] Namespace ${ns} removed."
  return 0
}

run_with_namespace_progress() {
  local label="$1"
  local ns="$2"
  shift 2

  "$@" &
  local cmd_pid=$!
  local start_ts now_ts elapsed pods total ready
  start_ts="$(date +%s)"

  while kill -0 "$cmd_pid" >/dev/null 2>&1; do
    sleep 10
    if ! kill -0 "$cmd_pid" >/dev/null 2>&1; then
      break
    fi
    now_ts="$(date +%s)"
    elapsed=$((now_ts - start_ts))
    pods="$(kubectl -n "$ns" get pods --no-headers 2>/dev/null || true)"
    if [[ -n "$pods" ]]; then
      total="$(printf '%s\n' "$pods" | awk 'NF{c++} END{print c+0}')"
      ready="$(printf '%s\n' "$pods" | awk 'NF{split($2,a,"/"); if (a[1]==a[2]) c++} END{print c+0}')"
      echo "[progress] ${label}: ${ready}/${total} pods ready (elapsed ${elapsed}s)"
    else
      echo "[progress] ${label}: waiting for first pods (elapsed ${elapsed}s)"
    fi
  done

  wait "$cmd_pid"
}

longhorn_release_status() {
  helm status "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE" 2>/dev/null \
    | awk -F': ' '/^STATUS:/ {print tolower($2); exit}'
}

longhorn_release_metadata_present() {
  local count
  count="$(kubectl -n "$LONGHORN_NAMESPACE" get secret,configmap -l "owner=helm,name=${LONGHORN_RELEASE_NAME}" --no-headers 2>/dev/null | awk 'NF{c++} END{print c+0}' || true)"
  [[ "${count:-0}" != "0" ]]
}

repair_stale_longhorn_release() {
  local status="$1"
  local reason

  if [[ -n "$status" ]]; then
    reason="status=${status}"
  else
    reason="orphaned_helm_metadata"
  fi

  if ! is_true "$ALLOW_DESTRUCTIVE_LONGHORN_REPAIR"; then
    echo "Error: detected stale Longhorn release (${reason}), but destructive auto-repair is disabled." >&2
    echo "Refusing to delete Longhorn resources during start/bootstrap." >&2
    echo "If you really want this automatic cleanup, rerun with: ALLOW_DESTRUCTIVE_LONGHORN_REPAIR=true ./kubeton start" >&2
    return 1
  fi

  if [[ -n "$status" ]]; then
    echo "[baremetal] Longhorn Helm release is in state '${status}', resetting stale release state ..."
  else
    echo "[baremetal] Longhorn Helm metadata exists without a healthy deployed release; resetting stale release state ..."
  fi

  # Uninstall hook can fail when deleting-confirmation-flag is false.
  helm uninstall "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE" --no-hooks >/dev/null 2>&1 || true
  kubectl -n "$LONGHORN_NAMESPACE" delete secret,configmap -l "owner=helm,name=${LONGHORN_RELEASE_NAME}" --ignore-not-found >/dev/null 2>&1 || true
  cleanup_longhorn_force || true
}

ensure_longhorn_installed() {
  require_bin helm
  require_bin kubectl
  if [[ ! "$LONGHORN_CHART_VERSION" =~ ^1\. ]]; then
    echo "Error: LONGHORN_CHART_VERSION must be a v1.x release, got: $LONGHORN_CHART_VERSION" >&2
    exit 1
  fi

  recover_stuck_longhorn_namespace

  # Previous failed uninstall can leave namespace in Terminating state.
  # Helm install cannot create release secrets there until namespace recovers.
  ensure_namespace_not_terminating "$LONGHORN_NAMESPACE" 240

  local lh_status=""
  lh_status="$(longhorn_release_status || true)"
  if [[ -n "$lh_status" && "$lh_status" != "deployed" ]]; then
    repair_stale_longhorn_release "$lh_status"
    recover_stuck_longhorn_namespace
    ensure_namespace_not_terminating "$LONGHORN_NAMESPACE" 240
  elif [[ -z "$lh_status" ]] && kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1 && longhorn_release_metadata_present; then
    repair_stale_longhorn_release ""
    recover_stuck_longhorn_namespace
    ensure_namespace_not_terminating "$LONGHORN_NAMESPACE" 240
  fi

  ensure_helm_repo "longhorn" "https://charts.longhorn.io"
  helm repo update longhorn >/dev/null

  local longhorn_selector_values_file=""
  local -a longhorn_extra_args=()
  if [[ -n "${LONGHORN_NODE_SELECTOR:-}" ]]; then
    local -a selector_pairs=()
    local kubectl_selector=""
    local pair
    local matched_nodes=0

    parse_selector_pairs "$LONGHORN_NODE_SELECTOR" selector_pairs || return 1
    for pair in "${selector_pairs[@]}"; do
      if [[ -n "$kubectl_selector" ]]; then
        kubectl_selector+=","
      fi
      kubectl_selector+="$pair"
    done

    matched_nodes="$(kubectl get nodes -l "$kubectl_selector" --no-headers 2>/dev/null | awk 'NF{c++} END{print c+0}')"
    if [[ "${matched_nodes:-0}" == "0" ]]; then
      echo "Error: LONGHORN_NODE_SELECTOR='${LONGHORN_NODE_SELECTOR}' matched 0 Kubernetes nodes." >&2
      echo "Label at least one node and retry. Example:" >&2
      echo "  kubectl label node <node-name> node.longhorn.io/create-default-disk=true" >&2
      return 1
    fi
    if [[ "$LONGHORN_DEFAULT_REPLICA_COUNT" =~ ^[0-9]+$ ]] && (( matched_nodes < LONGHORN_DEFAULT_REPLICA_COUNT )); then
      echo "Warning: LONGHORN_NODE_SELECTOR matches ${matched_nodes} nodes, which is less than LONGHORN_DEFAULT_REPLICA_COUNT=${LONGHORN_DEFAULT_REPLICA_COUNT}." >&2
    fi

    longhorn_selector_values_file="$(build_longhorn_selector_values_file "$LONGHORN_NODE_SELECTOR")"
    longhorn_extra_args+=(-f "$longhorn_selector_values_file")
    echo "[baremetal] Restricting Longhorn components to nodes: ${LONGHORN_NODE_SELECTOR} (matched ${matched_nodes} node(s))"
  fi

  echo "[baremetal] Installing/ensuring Longhorn ${LONGHORN_CHART_VERSION} ..."
  echo "[baremetal] Waiting for Longhorn components to become Ready (timeout 40m) ..."
  local install_rc=0
  run_with_namespace_progress "longhorn" "$LONGHORN_NAMESPACE" \
    helm upgrade --install "$LONGHORN_RELEASE_NAME" "$LONGHORN_CHART" \
    "${longhorn_extra_args[@]}" \
    --version "$LONGHORN_CHART_VERSION" \
    -n "$LONGHORN_NAMESPACE" \
    --create-namespace \
    --set-string "defaultSettings.defaultReplicaCount=${LONGHORN_DEFAULT_REPLICA_COUNT}" \
    --set "persistence.defaultClassReplicaCount=${LONGHORN_DEFAULT_REPLICA_COUNT}" \
    --disable-openapi-validation \
    --wait \
    --timeout 40m || install_rc=$?

  if [[ -n "$longhorn_selector_values_file" ]]; then
    rm -f "$longhorn_selector_values_file" >/dev/null 2>&1 || true
  fi
  if (( install_rc != 0 )); then
    return "$install_rc"
  fi
}

ensure_longhorn_crypto_secret() {
  require_bin openssl
  if kubectl -n "$LONGHORN_NAMESPACE" get secret "$LONGHORN_CRYPTO_SECRET_NAME" >/dev/null 2>&1; then
    return
  fi

  echo "[baremetal] Creating Longhorn encryption secret ${LONGHORN_CRYPTO_SECRET_NAME} ..."
  kubectl -n "$LONGHORN_NAMESPACE" create secret generic "$LONGHORN_CRYPTO_SECRET_NAME" \
    --from-literal=CRYPTO_KEY_VALUE="$(openssl rand -base64 48)" \
    --from-literal=CRYPTO_KEY_PROVIDER=secret \
    --from-literal=CRYPTO_KEY_CIPHER=aes-xts-plain64 \
    --from-literal=CRYPTO_KEY_HASH=sha256 \
    --from-literal=CRYPTO_KEY_SIZE=256 \
    --from-literal=CRYPTO_PBKDF=argon2i >/dev/null
}

ensure_encrypted_storage_class() {
  echo "[baremetal] Applying encrypted StorageClass ${ENCRYPTED_SC_NAME} ..."
  cat <<EOF | kubectl apply -f - >/dev/null
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: ${ENCRYPTED_SC_NAME}
provisioner: driver.longhorn.io
allowVolumeExpansion: true
reclaimPolicy: Delete
volumeBindingMode: Immediate
parameters:
  numberOfReplicas: "${LONGHORN_DEFAULT_REPLICA_COUNT}"
  staleReplicaTimeout: "2880"
  encrypted: "true"
  csi.storage.k8s.io/provisioner-secret-name: "${LONGHORN_CRYPTO_SECRET_NAME}"
  csi.storage.k8s.io/provisioner-secret-namespace: "${LONGHORN_NAMESPACE}"
  csi.storage.k8s.io/node-publish-secret-name: "${LONGHORN_CRYPTO_SECRET_NAME}"
  csi.storage.k8s.io/node-publish-secret-namespace: "${LONGHORN_NAMESPACE}"
  csi.storage.k8s.io/node-stage-secret-name: "${LONGHORN_CRYPTO_SECRET_NAME}"
  csi.storage.k8s.io/node-stage-secret-namespace: "${LONGHORN_NAMESPACE}"
  csi.storage.k8s.io/node-expand-secret-name: "${LONGHORN_CRYPTO_SECRET_NAME}"
  csi.storage.k8s.io/node-expand-secret-namespace: "${LONGHORN_NAMESPACE}"
EOF
}

ensure_localdev_encrypted_storage_class() {
  local base_sc="$1"
  local provisioner reclaim_policy volume_binding_mode allow_expand existing_provisioner

  provisioner="$(kubectl get storageclass "$base_sc" -o jsonpath='{.provisioner}')"
  reclaim_policy="$(kubectl get storageclass "$base_sc" -o jsonpath='{.reclaimPolicy}')"
  volume_binding_mode="$(kubectl get storageclass "$base_sc" -o jsonpath='{.volumeBindingMode}')"
  allow_expand="$(kubectl get storageclass "$base_sc" -o jsonpath='{.allowVolumeExpansion}')"

  [[ -z "$provisioner" ]] && { echo "Error: failed to read provisioner for StorageClass $base_sc" >&2; exit 1; }

  if kubectl get storageclass "$ENCRYPTED_SC_NAME" >/dev/null 2>&1; then
    existing_provisioner="$(kubectl get storageclass "$ENCRYPTED_SC_NAME" -o jsonpath='{.provisioner}')"
    if [[ "$existing_provisioner" == "$provisioner" ]]; then
      return
    fi
    echo "[localdev] Replacing StorageClass ${ENCRYPTED_SC_NAME} (old provisioner=${existing_provisioner}, new provisioner=${provisioner}) ..."
    kubectl delete storageclass "$ENCRYPTED_SC_NAME" --ignore-not-found >/dev/null
  fi

  [[ -z "$reclaim_policy" ]] && reclaim_policy="Delete"
  [[ -z "$volume_binding_mode" ]] && volume_binding_mode="Immediate"
  [[ -z "$allow_expand" ]] && allow_expand="true"

  echo "[localdev] Applying StorageClass ${ENCRYPTED_SC_NAME} (provisioner=${provisioner}, base=${base_sc}) ..."
  cat <<EOF | kubectl apply -f - >/dev/null
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: ${ENCRYPTED_SC_NAME}
provisioner: ${provisioner}
allowVolumeExpansion: ${allow_expand}
reclaimPolicy: ${reclaim_policy}
volumeBindingMode: ${volume_binding_mode}
EOF
}

ensure_vault_installed() {
  local vault_storage_class="${1:-longhorn}"
  require_bin helm
  ensure_namespace_not_terminating "$VAULT_NAMESPACE" 240
  ensure_helm_repo "hashicorp" "https://helm.releases.hashicorp.com"
  helm repo update hashicorp >/dev/null

  echo "[bootstrap] Installing/ensuring Vault chart ${VAULT_CHART_VERSION} ..."
  echo "[bootstrap] Waiting for Vault components to become Ready (timeout 30m) ..."
  run_with_namespace_progress "vault" "$VAULT_NAMESPACE" \
    helm upgrade --install "$VAULT_RELEASE_NAME" "$VAULT_CHART" \
    --version "$VAULT_CHART_VERSION" \
    -n "$VAULT_NAMESPACE" \
    --create-namespace \
    --set "server.ha.enabled=false" \
    --set "server.standalone.enabled=true" \
    --set "server.dataStorage.enabled=true" \
    --set-string "server.dataStorage.storageClass=${vault_storage_class}" \
    --set "injector.enabled=false" \
    --wait \
    --timeout 30m
}

vault_exec() {
  kubectl -n "$VAULT_NAMESPACE" exec "${VAULT_RELEASE_NAME}-0" -- "$@"
}

reset_localdev_vault() {
  echo "[localdev] Resetting Vault release/namespace for local recovery ..."
  helm uninstall "$VAULT_RELEASE_NAME" -n "$VAULT_NAMESPACE" >/dev/null 2>&1 || true
  kubectl delete namespace "$VAULT_NAMESPACE" --ignore-not-found >/dev/null 2>&1 || true
  wait_namespace_gone "$VAULT_NAMESPACE" 240 || true
}

vault_status_with_retry() {
  local deadline=$(( $(date +%s) + 180 ))
  local status initialized
  while (( $(date +%s) < deadline )); do
    status="$(vault_exec vault status 2>/dev/null || true)"
    initialized="$(printf '%s\n' "$status" | awk '/^Initialized[[:space:]]+/ {print tolower($2); exit}')"
    if [[ "$initialized" == "true" || "$initialized" == "false" ]]; then
      printf '%s' "$status"
      return 0
    fi
    sleep 3
  done
  printf '%s' "${status:-}"
  return 1
}

verify_vault_data_path_writable() {
  local check_out
  check_out="$(vault_exec sh -ec '
    test -d /vault/data
    touch /vault/data/.kubeton-rw-test
    rm -f /vault/data/.kubeton-rw-test
  ' 2>&1)" && return 0

  echo "Error: Vault data path /vault/data is not writable in ${VAULT_NAMESPACE}/${VAULT_RELEASE_NAME}-0." >&2
  if [[ -n "$check_out" ]]; then
    echo "Detail: $(printf '%s' "$check_out" | tr '\n' ' ')" >&2
  fi
  echo "This usually means the underlying PVC/PV/Longhorn volume is unhealthy (for example I/O error)." >&2
  echo "Check: kubectl -n ${VAULT_NAMESPACE} describe pod ${VAULT_RELEASE_NAME}-0 ; kubectl -n ${VAULT_NAMESPACE} get pvc ; kubectl -n longhorn-system get volumes.longhorn.io -o wide" >&2
  return 1
}

ensure_vault_bootstrap_secret_from_env() {
  local env_unseal_key env_root_token
  if [[ -z "$VAULT_BOOTSTRAP_UNSEAL_KEY" || -z "$VAULT_BOOTSTRAP_ROOT_TOKEN" ]]; then
    return 1
  fi
  env_unseal_key="$(sanitize_compact "$VAULT_BOOTSTRAP_UNSEAL_KEY")"
  env_root_token="$(sanitize_compact "$VAULT_BOOTSTRAP_ROOT_TOKEN")"
  if [[ -z "$env_unseal_key" || -z "$env_root_token" ]]; then
    echo "Error: provided Vault bootstrap credentials are empty after sanitization." >&2
    return 1
  fi
  echo "[baremetal] Recreating missing Vault bootstrap secret ${VAULT_BOOTSTRAP_SECRET} from environment ..."
  kubectl -n "$VAULT_NAMESPACE" create secret generic "$VAULT_BOOTSTRAP_SECRET" \
    --from-literal=unseal_key="$env_unseal_key" \
    --from-literal=root_token="$env_root_token" \
    --dry-run=client -o yaml | kubectl apply -f - >/dev/null
}

initialize_and_unseal_vault() {
  local status init_out unseal_key root_token initialized sealed

  if ! status="$(vault_status_with_retry)"; then
    echo "Error: failed to get parseable Vault status from ${VAULT_NAMESPACE}/${VAULT_RELEASE_NAME}-0." >&2
    echo "Check pod logs: kubectl -n ${VAULT_NAMESPACE} logs ${VAULT_RELEASE_NAME}-0" >&2
    exit 1
  fi
  initialized="$(printf '%s\n' "$status" | awk '/^Initialized[[:space:]]+/ {print tolower($2); exit}')"
  if [[ "$initialized" == "false" ]]; then
    echo "[baremetal] Initializing Vault ..." >&2
    init_out="$(vault_exec vault operator init -key-shares=1 -key-threshold=1)"
    unseal_key="$(printf '%s\n' "$init_out" | awk -F': ' '/Unseal Key 1:/ {print $2; exit}')"
    root_token="$(printf '%s\n' "$init_out" | awk -F': ' '/Initial Root Token:/ {print $2; exit}')"
    unseal_key="$(sanitize_compact "$unseal_key")"
    root_token="$(sanitize_compact "$root_token")"
    if [[ -z "$unseal_key" || -z "$root_token" ]]; then
      echo "Error: failed to parse Vault init output." >&2
      exit 1
    fi
    kubectl -n "$VAULT_NAMESPACE" create secret generic "$VAULT_BOOTSTRAP_SECRET" \
      --from-literal=unseal_key="$unseal_key" \
      --from-literal=root_token="$root_token" \
      --dry-run=client -o yaml | kubectl apply -f - >/dev/null
  elif [[ "$initialized" != "true" ]]; then
    echo "Error: unable to parse Vault initialized state." >&2
    echo "Vault status output:" >&2
    printf '%s\n' "$status" >&2
    exit 1
  fi

  if ! kubectl -n "$VAULT_NAMESPACE" get secret "$VAULT_BOOTSTRAP_SECRET" >/dev/null 2>&1; then
    if [[ "$initialized" == "true" ]] && ensure_vault_bootstrap_secret_from_env; then
      :
    else
      echo "Error: missing Vault bootstrap secret $VAULT_BOOTSTRAP_SECRET in namespace $VAULT_NAMESPACE" >&2
      if [[ "$initialized" == "true" ]]; then
        echo "Vault is already initialized. Provide existing credentials via:" >&2
        echo "  VAULT_BOOTSTRAP_UNSEAL_KEY=<unseal-key> VAULT_BOOTSTRAP_ROOT_TOKEN=<root-token> ./kubeton start" >&2
      fi
      exit 1
    fi
  fi

  unseal_key="$(kubectl -n "$VAULT_NAMESPACE" get secret "$VAULT_BOOTSTRAP_SECRET" -o jsonpath='{.data.unseal_key}' | base64 -d)"
  root_token="$(kubectl -n "$VAULT_NAMESPACE" get secret "$VAULT_BOOTSTRAP_SECRET" -o jsonpath='{.data.root_token}' | base64 -d)"
  unseal_key="$(sanitize_compact "$unseal_key")"
  root_token="$(sanitize_compact "$root_token")"
  if [[ -z "$unseal_key" || -z "$root_token" ]]; then
    echo "Error: Vault bootstrap secret ${VAULT_BOOTSTRAP_SECRET} is missing required keys." >&2
    exit 1
  fi

  status="$(vault_status_with_retry || true)"
  sealed="$(printf '%s\n' "$status" | awk '/^Sealed[[:space:]]+/ {print tolower($2); exit}')"
  if [[ "$sealed" == "true" ]]; then
    echo "[baremetal] Unsealing Vault ..." >&2
    vault_exec vault operator unseal "$unseal_key" >/dev/null
  fi

  printf '%s' "$root_token"
}

configure_vault_for_ton() {
  local root_token="$1"
  local ton_token

  root_token="$(sanitize_compact "$root_token")"
  if [[ -z "$root_token" ]]; then
    echo "Error: empty root token for Vault configuration." >&2
    return 1
  fi
  verify_vault_data_path_writable || return 1

  echo "[baremetal] Configuring Vault Transit key and policy ..."
  vault_exec sh -ec "export VAULT_TOKEN='${root_token}'; vault secrets list | grep -q '^transit/' || vault secrets enable -path=transit transit" || return 1
  vault_exec sh -ec "export VAULT_TOKEN='${root_token}'; vault read transit/keys/${VAULT_TRANSIT_KEY} >/dev/null 2>&1 || vault write -f transit/keys/${VAULT_TRANSIT_KEY}" || return 1
  vault_exec sh -ec "export VAULT_TOKEN='${root_token}'; printf '%s\n' 'path \"transit/encrypt/${VAULT_TRANSIT_KEY}\" { capabilities = [\"update\"] }' 'path \"transit/decrypt/${VAULT_TRANSIT_KEY}\" { capabilities = [\"update\"] }' | vault policy write ${VAULT_TON_POLICY_NAME} -" || return 1
  ton_token="$(vault_exec sh -ec "export VAULT_TOKEN='${root_token}'; vault token create -policy=${VAULT_TON_POLICY_NAME} -period=${VAULT_TOKEN_PERIOD} -orphan -field=token")" || return 1
  ton_token="$(sanitize_compact "$ton_token")"
  if [[ -z "$ton_token" ]]; then
    echo "Error: failed to create TON Vault token." >&2
    return 1
  fi

  ensure_namespace "$TON_NAMESPACE"
  kubectl -n "$TON_NAMESPACE" create secret generic "$TON_VAULT_CREDS_SECRET" \
    --from-literal=VAULT_ADDR="$VAULT_ADDR_INTERNAL" \
    --from-literal=VAULT_TOKEN="$ton_token" \
    --dry-run=client -o yaml | kubectl apply -f - >/dev/null || return 1

  return 0
}

ensure_baremetal_stack() {
  require_bin kubectl
  require_bin helm
  require_bin openssl
  require_bin base64

  ensure_longhorn_installed
  ensure_longhorn_crypto_secret
  ensure_encrypted_storage_class
  ensure_vault_installed "longhorn"
  local root_token
  root_token="$(initialize_and_unseal_vault)"
  configure_vault_for_ton "$root_token"
}

ensure_localdev_stack() {
  require_bin kubectl
  require_bin helm
  require_bin base64

  local base_sc
  local root_token
  base_sc="$(resolve_localdev_storage_class)"
  ensure_localdev_encrypted_storage_class "$base_sc"
  ensure_vault_installed "$base_sc"
  root_token="$(initialize_and_unseal_vault)"

  if ! configure_vault_for_ton "$root_token"; then
    echo "[localdev] Vault configuration failed; reinstalling Vault and reinitializing ..." >&2
    reset_localdev_vault
    ensure_vault_installed "$base_sc"
    root_token="$(initialize_and_unseal_vault)"
    if ! configure_vault_for_ton "$root_token"; then
      echo "Error: Vault configuration is still failing after local recovery." >&2
      exit 1
    fi
  fi
}

ensure_auto_bootstrap_stack() {
  if cluster_is_k3d; then
    ensure_localdev_stack
    return
  fi
  ensure_baremetal_stack
}

validate_external_key_prereqs() {
  if is_true "$SKIP_KEY_PREREQ_CHECK"; then
    return
  fi
  if ! kubectl get storageclass "$ENCRYPTED_SC_NAME" >/dev/null 2>&1; then
    echo "Error: missing StorageClass $ENCRYPTED_SC_NAME. Configure cloud/bare-metal prerequisite first." >&2
    exit 1
  fi
  if ! kubectl -n "$TON_NAMESPACE" get secret "$TON_VAULT_CREDS_SECRET" >/dev/null 2>&1; then
    echo "Error: missing secret $TON_VAULT_CREDS_SECRET in namespace $TON_NAMESPACE." >&2
    echo "Configure Vault/KMS prerequisites first or enable AUTO_BAREMETAL_BOOTSTRAP for bare-metal/local k3d." >&2
    exit 1
  fi
}

append_baremetal_key_overrides() {
  local -n target="$1"
  target+=(--set "tonNode.keyManagement.enabled=true")
  target+=(--set-string "tonNode.keyManagement.provider=vault")
  target+=(--set-string "tonNode.keyManagement.credentialsSecretRef=${TON_VAULT_CREDS_SECRET}")
  target+=(--set-string "tonNode.keyManagement.vaultTransitKey=${VAULT_TRANSIT_KEY}")
  target+=(--set-string "tonNode.keyManagement.encryptedBundle.storageClassName=${ENCRYPTED_SC_NAME}")
}

list_ton_pods() {
  kubectl get pods -A -l "$TON_POD_LABEL" \
    -o jsonpath='{range .items[*]}{.metadata.namespace}{"\t"}{.metadata.name}{"\t"}{.spec.nodeName}{"\n"}{end}'
}

list_ton_statefulsets() {
  kubectl get statefulsets -A -l "$TON_POD_LABEL" \
    -o jsonpath='{range .items[*]}{.metadata.namespace}{"\t"}{.metadata.name}{"\t"}{.spec.replicas}{"\n"}{end}'
}

set_ton_replicas() {
  local ns="$1"
  local name="$2"
  local replicas="$3"

  kubectl -n "$ns" scale statefulset "$name" --replicas="$replicas" >/dev/null
}

wait_pvc_bound() {
  local ns="$1"
  local pvc="$2"
  local timeout_seconds="${3:-300}"
  local deadline=$(( $(date +%s) + timeout_seconds ))
  local phase=""

  while (( $(date +%s) < deadline )); do
    phase="$(kubectl -n "$ns" get pvc "$pvc" -o jsonpath='{.status.phase}' 2>/dev/null || true)"
    if [[ "$phase" == "Bound" ]]; then
      return 0
    fi
    sleep 2
  done

  echo "Error: timeout waiting for PVC ${ns}/${pvc} to become Bound (last phase='${phase:-unknown}')." >&2
  return 1
}

wait_pod_ready() {
  local ns="$1"
  local pod="$2"
  local timeout_seconds="${3:-900}"
  local deadline=$(( $(date +%s) + timeout_seconds ))

  while (( $(date +%s) < deadline )); do
    if kubectl -n "$ns" wait --for=condition=Ready "pod/${pod}" --timeout=10s >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done

  echo "Error: timeout waiting for pod ${ns}/${pod} to become Ready." >&2
  return 1
}

wait_pod_gone() {
  local ns="$1"
  local pod="$2"
  local timeout_seconds="${3:-600}"
  local deadline=$(( $(date +%s) + timeout_seconds ))

  while (( $(date +%s) < deadline )); do
    if ! kubectl -n "$ns" get pod "$pod" >/dev/null 2>&1; then
      return 0
    fi
    sleep 2
  done

  echo "Error: timeout waiting for pod ${ns}/${pod} to be deleted." >&2
  return 1
}

create_replica_pvc_from_ordinal0() {
  local ns="$1"
  local sts="$2"
  local claim_prefix="$3"
  local ordinal="$4"
  local source_pvc="${claim_prefix}-${sts}-0"
  local target_pvc="${claim_prefix}-${sts}-${ordinal}"
  local storage_request storage_class volume_mode access_modes_raw
  local -a access_modes=()

  if kubectl -n "$ns" get pvc "$target_pvc" >/dev/null 2>&1; then
    return 0
  fi
  if ! kubectl -n "$ns" get pvc "$source_pvc" >/dev/null 2>&1; then
    return 10
  fi

  storage_request="$(kubectl -n "$ns" get pvc "$source_pvc" -o jsonpath='{.spec.resources.requests.storage}' 2>/dev/null || true)"
  storage_class="$(kubectl -n "$ns" get pvc "$source_pvc" -o jsonpath='{.spec.storageClassName}' 2>/dev/null || true)"
  volume_mode="$(kubectl -n "$ns" get pvc "$source_pvc" -o jsonpath='{.spec.volumeMode}' 2>/dev/null || true)"
  access_modes_raw="$(kubectl -n "$ns" get pvc "$source_pvc" -o jsonpath='{.spec.accessModes[*]}' 2>/dev/null || true)"
  read -r -a access_modes <<<"$access_modes_raw"

  if [[ -z "$storage_request" ]]; then
    echo "Error: failed to derive storage request from ${ns}/${source_pvc}." >&2
    return 1
  fi
  if [[ ${#access_modes[@]} -eq 0 ]]; then
    access_modes=("ReadWriteOnce")
  fi

  {
    echo "apiVersion: v1"
    echo "kind: PersistentVolumeClaim"
    echo "metadata:"
    echo "  name: ${target_pvc}"
    echo "  namespace: ${ns}"
    echo "spec:"
    echo "  accessModes:"
    local mode
    for mode in "${access_modes[@]}"; do
      echo "  - ${mode}"
    done
    if [[ -n "$storage_class" ]]; then
      echo "  storageClassName: ${storage_class}"
    fi
    if [[ -n "$volume_mode" ]]; then
      echo "  volumeMode: ${volume_mode}"
    fi
    echo "  resources:"
    echo "    requests:"
    echo "      storage: ${storage_request}"
  } | kubectl apply -f - >/dev/null

  return 0
}

get_single_ton_statefulset() {
  local -n out_ns="$1"
  local -n out_sts="$2"
  local -n out_replicas="$3"
  local -a rows=()
  local row ns sts replicas count=0

  mapfile -t rows < <(list_ton_statefulsets)
  if [[ ${#rows[@]} -eq 0 || -z "${rows[0]}" ]]; then
    echo "Error: no TON StatefulSets found." >&2
    return 1
  fi

  for row in "${rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    [[ -z "$ns" || -z "$sts" ]] && continue
    out_ns="$ns"
    out_sts="$sts"
    out_replicas="${replicas:-0}"
    ((count+=1))
  done

  if (( count == 1 )); then
    return 0
  fi

  echo "Error: found ${count} TON StatefulSets; add command requires exactly one." >&2
  for row in "${rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    echo "  - ${ns}/${sts} replicas=${replicas:-0}" >&2
  done
  return 1
}

run_add() {
  require_bin kubectl
  local ns sts replicas
  local new_ordinal new_replicas
  local new_pod node_name
  local -a claim_prefixes=("ton-work" "mytoncore" "keybundle")
  local -a prepared_pvcs=()
  local claim_prefix pvc pv

  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton add" >&2
    exit 1
  fi

  get_single_ton_statefulset ns sts replicas || exit 1
  if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
    echo "Error: invalid replicas value for ${ns}/${sts}: ${replicas}" >&2
    exit 1
  fi

  if should_bootstrap_baremetal; then
    require_bin helm
    ensure_longhorn_installed
    ensure_longhorn_crypto_secret
    ensure_encrypted_storage_class
  fi
  validate_external_key_prereqs

  new_ordinal="$replicas"
  new_replicas=$((replicas + 1))

  echo "Preparing PVCs for new replica ${ns}/${sts}-${new_ordinal} ..."
  for claim_prefix in "${claim_prefixes[@]}"; do
    if create_replica_pvc_from_ordinal0 "$ns" "$sts" "$claim_prefix" "$new_ordinal"; then
      prepared_pvcs+=("${claim_prefix}-${sts}-${new_ordinal}")
    else
      case "$?" in
        10)
          ;;
        *)
          echo "Error: failed to prepare PVC for claim prefix ${claim_prefix}." >&2
          exit 1
          ;;
      esac
    fi
  done

  for pvc in "${prepared_pvcs[@]}"; do
    wait_pvc_bound "$ns" "$pvc" 300
    pv="$(kubectl -n "$ns" get pvc "$pvc" -o jsonpath='{.spec.volumeName}' 2>/dev/null || true)"
    if [[ -n "$pv" ]]; then
      kubectl -n "$LONGHORN_NAMESPACE" get volumes.longhorn.io "$pv" >/dev/null 2>&1 || true
    fi
  done

  echo "Scaling ${ns}/${sts} from ${replicas} to ${new_replicas} ..."
  set_ton_replicas "$ns" "$sts" "$new_replicas"

  new_pod="${sts}-${new_ordinal}"
  echo "Waiting for ${ns}/${new_pod} to become Ready ..."
  wait_pod_ready "$ns" "$new_pod" 1200

  node_name="$(kubectl -n "$ns" get pod "$new_pod" -o jsonpath='{.spec.nodeName}' 2>/dev/null || true)"
  [[ -z "$node_name" ]] && node_name="N/A"
  echo "Added TON replica: ${ns}/${new_pod} on node ${node_name}."
  echo "Next step: execute ./kubeton backup-keys"
}

run_del() {
  require_bin kubectl
  if [[ $# -ne 0 ]]; then
    echo "Error: kubeton del does not take a pod name; it always removes the tail replica (highest ordinal)." >&2
    echo "Error: usage: kubeton del" >&2
    exit 1
  fi

  local ns sts replicas ordinal pod
  local -a claim_prefixes=("ton-work" "mytoncore" "keybundle")
  local -a pvc_names=()
  local -a pv_names=()
  local claim_prefix pvc pv

  get_single_ton_statefulset ns sts replicas || exit 1

  replicas="$(kubectl -n "$ns" get statefulset "$sts" -o jsonpath='{.spec.replicas}' 2>/dev/null || true)"
  if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
    echo "Error: cannot read replicas for ${ns}/${sts}." >&2
    exit 1
  fi
  if (( replicas <= 0 )); then
    echo "Error: StatefulSet ${ns}/${sts} has no replicas to delete." >&2
    exit 1
  fi

  ordinal=$((replicas - 1))
  pod="${sts}-${ordinal}"

  confirm_or_exit "This will remove the tail TON replica ${ns}/${pod}, delete its PVC/PV (including Longhorn volume if present), and scale ${sts} to $((replicas - 1)). Continue?"

  for claim_prefix in "${claim_prefixes[@]}"; do
    pvc="${claim_prefix}-${sts}-${ordinal}"
    pvc_names+=("$pvc")
    pv="$(kubectl -n "$ns" get pvc "$pvc" -o jsonpath='{.spec.volumeName}' 2>/dev/null || true)"
    if [[ -n "$pv" ]]; then
      pv_names+=("$pv")
    fi
  done

  echo "Scaling ${ns}/${sts} from ${replicas} to $((replicas - 1)) ..."
  set_ton_replicas "$ns" "$sts" "$((replicas - 1))"
  wait_pod_gone "$ns" "$pod" 600 || true

  echo "Deleting PVCs for ${ns}/${pod} ..."
  for pvc in "${pvc_names[@]}"; do
    kubectl -n "$ns" delete pvc "$pvc" --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  if [[ ${#pv_names[@]} -gt 0 ]]; then
    echo "Deleting PV and Longhorn volume resources ..."
  fi
  for pv in "${pv_names[@]}"; do
    kubectl delete pv "$pv" --ignore-not-found --wait=false >/dev/null 2>&1 || true
    kubectl -n "$LONGHORN_NAMESPACE" delete volumes.longhorn.io "$pv" --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  echo "Replica ${ns}/${pod} deleted."
}

pause_operator_reconcile() {
  local -n deploy_names_ref="$1"
  local -n deploy_replicas_ref="$2"

  mapfile -t deploy_rows < <(kubectl -n "$OP_NAMESPACE" get deploy -l "app.kubernetes.io/instance=${RELEASE_NAME}" \
    -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.spec.replicas}{"\n"}{end}')
  if [[ ${#deploy_rows[@]} -eq 0 || -z "${deploy_rows[0]}" ]]; then
    echo "Warning: no operator deployments found in namespace ${OP_NAMESPACE}; backup/restore may race with reconciliation." >&2
    return 0
  fi

  local row name replicas
  for row in "${deploy_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r name replicas <<<"$row"
    [[ -z "$name" ]] && continue
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=1
    fi
    deploy_names_ref+=("$name")
    deploy_replicas_ref+=("$replicas")
  done

  echo "Pausing operator reconciliation (scaling deployments in ${OP_NAMESPACE} to 0) ..."
  local i
  for i in "${!deploy_names_ref[@]}"; do
    kubectl -n "$OP_NAMESPACE" scale deployment "${deploy_names_ref[$i]}" --replicas=0 >/dev/null
  done
}

resume_operator_reconcile() {
  local -n deploy_names_ref="$1"
  local -n deploy_replicas_ref="$2"
  local i

  [[ ${#deploy_names_ref[@]} -eq 0 ]] && return 0

  echo "Resuming operator reconciliation in ${OP_NAMESPACE} ..."
  for i in "${!deploy_names_ref[@]}"; do
    kubectl -n "$OP_NAMESPACE" scale deployment "${deploy_names_ref[$i]}" --replicas="${deploy_replicas_ref[$i]}" >/dev/null 2>&1 || true
  done
}

wait_statefulset_pods_gone() {
  local ns="$1"
  local sts="$2"
  local deadline=$(( $(date +%s) + 900 ))
  while (( $(date +%s) < deadline )); do
    local count
    count="$(kubectl -n "$ns" get pods -l "app.kubernetes.io/instance=${sts},app.kubernetes.io/name=ton-node" -o name 2>/dev/null | wc -l | tr -d '[:space:]')"
    if [[ "${count:-0}" == "0" ]]; then
      return 0
    fi
    sleep 2
  done
  echo "Error: timeout waiting for pods of ${ns}/${sts} to terminate" >&2
  return 1
}

trigger_key_backup_once() {
  local ns="$1"
  local pod="$2"
  local deadline

  if ! kubectl -n "$ns" exec "$pod" -c key-backup -- sh -ec 'rm -f /tmp/key-backup.done /tmp/key-backup.failed; : > /tmp/key-backup.request' >/dev/null 2>&1; then
    echo "Error: failed to trigger key backup in ${ns}/${pod} (container key-backup)." >&2
    return 1
  fi

  deadline=$(( $(date +%s) + 300 ))
  while (( $(date +%s) < deadline )); do
    local status
    status="$(kubectl -n "$ns" exec "$pod" -c key-backup -- sh -ec '
      if [ -s /tmp/key-backup.done ]; then
        echo done
      elif [ -s /tmp/key-backup.failed ]; then
        echo failed
      else
        echo waiting
      fi
    ' 2>/dev/null || true)"
    status="${status%%$'\n'*}"
    case "$status" in
      done)
        return 0
        ;;
      failed)
        local fail_reason
        fail_reason="$(kubectl -n "$ns" exec "$pod" -c key-backup -- sh -ec 'cat /tmp/key-backup.failed' 2>/dev/null || true)"
        fail_reason="$(printf '%s' "$fail_reason" | tr '\n' ' ' | sed -e 's/[[:space:]]\+/ /g' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
        if [[ -z "$fail_reason" ]]; then
          fail_reason="backup sidecar reported failure"
        fi
        echo "Error: manual key backup failed in ${ns}/${pod}: ${fail_reason}" >&2
        return 1
        ;;
      *)
        sleep 2
        ;;
    esac
  done

  echo "Error: timeout waiting for manual key backup completion in ${ns}/${pod}" >&2
  return 1
}

pod_has_encrypted_bundle() {
  local ns="$1"
  local pod="$2"
  kubectl -n "$ns" exec "$pod" -c key-backup -- sh -ec '
    bundle_file="${KEY_BUNDLE_FILE:-keys.bundle.enc}"
    meta_file="${KEY_BUNDLE_META_FILE:-keys.bundle.meta}"
    [ -s "/var/ton-key-bundle/${bundle_file}" ] && [ -s "/var/ton-key-bundle/${meta_file}" ]
  ' >/dev/null 2>&1
}

restore_bundle_to_pvc() {
  local ns="$1"
  local pvc="$2"
  local src_bundle_dir="$3"
  local helper_pod="kubeton-restore-$RANDOM-$RANDOM"

  cat <<EOF | kubectl -n "$ns" apply -f - >/dev/null
apiVersion: v1
kind: Pod
metadata:
  name: ${helper_pod}
spec:
  restartPolicy: Never
  containers:
    - name: restore
      image: busybox:1.36
      command: ["sh", "-c", "sleep 3600"]
      volumeMounts:
        - name: keybundle
          mountPath: /bundle
  volumes:
    - name: keybundle
      persistentVolumeClaim:
        claimName: ${pvc}
EOF

  if ! kubectl -n "$ns" wait --for=condition=Ready "pod/${helper_pod}" --timeout=120s >/dev/null; then
    kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
    return 1
  fi
  if ! kubectl -n "$ns" exec "$helper_pod" -- sh -ec 'find /bundle -mindepth 1 -maxdepth 1 -exec rm -rf {} +' >/dev/null 2>&1; then
    kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
    return 1
  fi
  if ! kubectl -n "$ns" cp "${src_bundle_dir}/." "${helper_pod}:/bundle" >/dev/null; then
    kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
    return 1
  fi
  kubectl -n "$ns" exec "$helper_pod" -- sh -ec 'find /bundle -type f -exec chmod 600 {} +' >/dev/null 2>&1 || true
  kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
}

restore_replica_from_backup() {
  local ns="$1"
  local sts="$2"
  local ordinal="$3"
  local input_dir="$4"

  local pvc="keybundle-${sts}-${ordinal}"
  local item_dir="${input_dir}/${ns}/${sts}/${ordinal}"
  local bundle_dir="${item_dir}/bundle"

  if [[ ! -d "$bundle_dir" ]]; then
    echo "Warning: missing backup bundle for ${ns}/${sts}/${ordinal}: ${bundle_dir}" >&2
    return 10
  fi

  if [[ -f "${item_dir}/SHA256SUMS" ]]; then
    if ! (cd "$item_dir" && sha256sum -c SHA256SUMS >/dev/null); then
      echo "Warning: SHA256SUMS verification failed for ${item_dir}; skipping this replica" >&2
      return 11
    fi
  else
    echo "Warning: missing ${item_dir}/SHA256SUMS; continuing without checksum verification"
  fi

  if ! kubectl -n "$ns" get pvc "$pvc" >/dev/null 2>&1; then
    echo "Warning: missing PVC ${ns}/${pvc}; skipping this replica" >&2
    return 11
  fi

  if ! restore_bundle_to_pvc "$ns" "$pvc" "$bundle_dir"; then
    echo "Warning: failed to restore ${ns}/${pvc} from ${bundle_dir}; skipping this replica" >&2
    return 11
  fi

  return 0
}

export_bundle_from_pvc() {
  local ns="$1"
  local sts="$2"
  local ordinal="$3"
  local output_dir="$4"
  local pvc="keybundle-${sts}-${ordinal}"
  local item_dir="$output_dir/$ns/$sts/$ordinal"
  local bundle_dir="$item_dir/bundle"
  local helper_pod="kubeton-backup-${sts}-${ordinal}-$RANDOM-$RANDOM"

  if ! kubectl -n "$ns" get pvc "$pvc" >/dev/null 2>&1; then
    echo "Warning: missing PVC ${ns}/${pvc}, skipping"
    return 0
  fi

  mkdir -p "$bundle_dir"

  cat <<EOF | kubectl -n "$ns" apply -f - >/dev/null
apiVersion: v1
kind: Pod
metadata:
  name: ${helper_pod}
spec:
  restartPolicy: Never
  containers:
    - name: backup
      image: busybox:1.36
      command: ["sh", "-c", "sleep 3600"]
      volumeMounts:
        - name: keybundle
          mountPath: /bundle
          readOnly: true
  volumes:
    - name: keybundle
      persistentVolumeClaim:
        claimName: ${pvc}
        readOnly: true
EOF

  if ! kubectl -n "$ns" wait --for=condition=Ready "pod/${helper_pod}" --timeout=120s >/dev/null; then
    kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
    echo "Error: helper pod ${ns}/${helper_pod} did not become Ready." >&2
    return 1
  fi

  if ! kubectl -n "$ns" cp "${helper_pod}:/bundle/." "$bundle_dir" >/dev/null; then
    kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
    echo "Error: failed to copy encrypted bundle from ${ns}/${helper_pod}." >&2
    return 1
  fi

  if find "$bundle_dir" -type f -print -quit | grep -q .; then
    if ! (cd "$item_dir" && find bundle -type f -print0 | sort -z | xargs -0 sha256sum > SHA256SUMS); then
      kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
      echo "Error: failed to write SHA256SUMS for ${ns}/${sts}/${ordinal}." >&2
      return 1
    fi
  else
    echo "Warning: ${ns}/${pvc} bundle directory is empty"
  fi

  kubectl -n "$ns" delete pod "$helper_pod" --ignore-not-found >/dev/null 2>&1 || true
  return 0
}

dash_line() {
  local width="$1"
  printf '%*s' "$width" '' | tr ' ' '-'
}

print_aligned_table_3col() {
  local h1="$1"
  local h2="$2"
  local h3="$3"
  shift 3
  local -a rows=("$@")
  local w1=${#h1}
  local w2=${#h2}
  local w3=${#h3}
  local row c1 c2 c3

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 <<<"$row"
    (( ${#c1} > w1 )) && w1=${#c1}
    (( ${#c2} > w2 )) && w2=${#c2}
    (( ${#c3} > w3 )) && w3=${#c3}
  done

  printf "| %-*s | %-*s | %-*s |\n" "$w1" "$h1" "$w2" "$h2" "$w3" "$h3"
  printf "|-%s-|-%s-|-%s-|\n" "$(dash_line "$w1")" "$(dash_line "$w2")" "$(dash_line "$w3")"
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 <<<"$row"
    printf "| %-*s | %-*s | %-*s |\n" "$w1" "$c1" "$w2" "$c2" "$w3" "$c3"
  done
}

print_aligned_table_5col() {
  local h1="$1"
  local h2="$2"
  local h3="$3"
  local h4="$4"
  local h5="$5"
  shift 5
  local -a rows=("$@")
  local w1=${#h1}
  local w2=${#h2}
  local w3=${#h3}
  local w4=${#h4}
  local w5=${#h5}
  local row c1 c2 c3 c4 c5

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 c4 c5 <<<"$row"
    (( ${#c1} > w1 )) && w1=${#c1}
    (( ${#c2} > w2 )) && w2=${#c2}
    (( ${#c3} > w3 )) && w3=${#c3}
    (( ${#c4} > w4 )) && w4=${#c4}
    (( ${#c5} > w5 )) && w5=${#c5}
  done

  printf "| %-*s | %-*s | %-*s | %-*s | %-*s |\n" \
    "$w1" "$h1" "$w2" "$h2" "$w3" "$h3" "$w4" "$h4" "$w5" "$h5"
  printf "|-%s-|-%s-|-%s-|-%s-|-%s-|\n" \
    "$(dash_line "$w1")" "$(dash_line "$w2")" "$(dash_line "$w3")" "$(dash_line "$w4")" "$(dash_line "$w5")"
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 c4 c5 <<<"$row"
    printf "| %-*s | %-*s | %-*s | %-*s | %-*s |\n" \
      "$w1" "$c1" "$w2" "$c2" "$w3" "$c3" "$w4" "$c4" "$w5" "$c5"
  done
}

bytes_to_gb() {
  local bytes="$1"
  if ! [[ "$bytes" =~ ^[0-9]+$ ]]; then
    echo "N/A"
    return
  fi
  awk -v b="$bytes" 'BEGIN { printf "%.2f GB", b/1024/1024/1024 }'
}

folder_size_gb() {
  local ns="$1"
  local pod="$2"
  local folder="$3"
  local bytes=""

  if bytes="$(kubectl -n "$ns" exec "$pod" -- bash -lc "du -s -B1 \"$folder\" 2>/dev/null | awk '{print \$1}'" 2>/dev/null)"; then
    bytes="${bytes%%$'\n'*}"
    bytes="$(printf '%s' "$bytes" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    bytes_to_gb "$bytes"
    return
  fi

  echo "N/A"
}

sync_value() {
  local ns="$1"
  local pod="$2"
  local output=""

  output="$(kubectl -n "$ns" exec "$pod" -- bash -lc 'shopt -s expand_aliases; if [[ -f ~/.bashrc ]]; then source ~/.bashrc >/dev/null 2>&1; fi; sync' 2>/dev/null || true)"
  output="${output//$'\r'/}"
  output="$(printf '%s\n' "$output" | awk 'NF{print; exit}')"
  output="$(printf '%s' "$output" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

  if [[ -z "$output" ]]; then
    output="$(kubectl -n "$ns" exec "$pod" -- bash -ic 'sync' 2>/dev/null || true)"
    output="${output//$'\r'/}"
    output="$(printf '%s\n' "$output" | awk 'NF{print; exit}')"
    output="$(printf '%s' "$output" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  fi

  if [[ -z "$output" ]]; then
    echo "N/A"
    return
  fi

  echo "$output"
}

run_install() {
  require_bin helm
  helm upgrade --install "$RELEASE_NAME" "$CHART_DIR" \
    -n "$OP_NAMESPACE" \
    --create-namespace \
    -f "$OP_VALUES_FILE"
}

run_bootstrap_baremetal() {
  require_bin kubectl
  require_bin helm
  if ! cluster_is_baremetal && ! cluster_is_k3d && ! is_true "$FORCE_BAREMETAL_BOOTSTRAP"; then
    echo "Cluster looks like cloud/managed (not bare-metal/local k3d)."
    echo "Use FORCE_BAREMETAL_BOOTSTRAP=true if you really want to bootstrap Longhorn+Vault here."
    exit 1
  fi
  ensure_auto_bootstrap_stack
  echo "[bootstrap] Completed."
}

run_start() {
  require_bin helm
  require_bin kubectl

  local replicas="${1:-}"
  local -a extra_overrides=()

  if should_bootstrap_baremetal; then
    ensure_auto_bootstrap_stack
    append_baremetal_key_overrides extra_overrides
  else
    validate_external_key_prereqs
  fi

  if [[ -n "$replicas" ]]; then
    if ! [[ "$replicas" =~ ^[1-9][0-9]*$ ]]; then
      echo "Error: replicas must be a positive integer." >&2
      exit 1
    fi
    helm upgrade "$RELEASE_NAME" "$CHART_DIR" \
      -n "$OP_NAMESPACE" \
      -f "$OP_VALUES_FILE" \
      -f "$TON_VALUES_FILE" \
      --set "tonNode.replicas=$replicas" \
      "${extra_overrides[@]}"
    return
  fi

  helm upgrade "$RELEASE_NAME" "$CHART_DIR" \
    -n "$OP_NAMESPACE" \
    -f "$OP_VALUES_FILE" \
    -f "$TON_VALUES_FILE" \
    "${extra_overrides[@]}"
}

run_upgrade() {
  require_bin helm
  require_bin kubectl
  if [[ $# -gt 1 ]]; then
    echo "Error: usage: kubeton upgrade [tag]" >&2
    exit 1
  fi
  local tag="${1:-latest}"
  if [[ "$tag" =~ [[:space:]] ]]; then
    echo "Error: image tag must not contain whitespace." >&2
    exit 1
  fi

  local -a extra_overrides=()
  if should_bootstrap_baremetal; then
    ensure_auto_bootstrap_stack
    append_baremetal_key_overrides extra_overrides
  else
    validate_external_key_prereqs
  fi

  helm upgrade "$RELEASE_NAME" "$CHART_DIR" \
    -n "$OP_NAMESPACE" \
    -f "$OP_VALUES_FILE" \
    -f "$TON_VALUES_FILE" \
    --set-string "tonNode.image=${TON_IMAGE_REPO}:${tag}" \
    "${extra_overrides[@]}" \
    --rollback-on-failure \
    --wait \
    --timeout 40m
}

run_backup_keys() {
  require_bin kubectl
  require_bin sha256sum
  require_bin date

  local default_output_root
  default_output_root="$(cd "$CHART_DIR/.." && pwd)/key-backups"
  local output_dir="${1:-$default_output_root/$(date -u +%Y%m%dT%H%M%SZ)}"
  if [[ $# -gt 1 ]]; then
    echo "Error: usage: kubeton backup-keys [output-dir]" >&2
    exit 1
  fi

  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  confirm_or_exit "This will trigger encrypted backup in each TON pod, scale StatefulSets to 0, export bundles, then scale back. Continue?"
  mkdir -p "$output_dir"

  local -a ns_list=()
  local -a sts_list=()
  local -a replicas_list=()
  local -a operator_deploy_names=()
  local -a operator_deploy_replicas=()
  local row ns sts replicas i ordinal pod
  local operator_paused=0
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    replicas="${replicas:-0}"
    ns_list+=("$ns")
    sts_list+=("$sts")
    replicas_list+=("$replicas")
  done

  local restore_required=1
  cleanup_restore() {
    [[ "${restore_required:-0}" -ne 1 ]] && return 0
    local i
    for i in "${!sts_list[@]}"; do
      set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" "${replicas_list[$i]}" >/dev/null 2>&1 || true
    done
    if [[ "${operator_paused:-0}" -eq 1 ]]; then
      resume_operator_reconcile operator_deploy_names operator_deploy_replicas || true
    fi
  }
  trap cleanup_restore EXIT INT TERM

  echo "Triggering manual encrypted bundle backup in each TON pod (parallel) ..."
  local -a trigger_pids=()
  local -a trigger_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      pod="${sts}-${ordinal}"
      trigger_key_backup_once "$ns" "$pod" &
      trigger_pids+=("$!")
      trigger_descs+=("${ns}/${pod}")
    done
  done

  local trigger_failed=0
  for i in "${!trigger_pids[@]}"; do
    if ! wait "${trigger_pids[$i]}"; then
      echo "Error: key backup trigger failed for ${trigger_descs[$i]}." >&2
      trigger_failed=1
    fi
  done
  if [[ "$trigger_failed" -ne 0 ]]; then
    echo "Error: one or more pod backup triggers failed." >&2
    return 1
  fi

  pause_operator_reconcile operator_deploy_names operator_deploy_replicas
  operator_paused=1

  echo "Scaling TON StatefulSets to 0 ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" 0
  done
  for i in "${!sts_list[@]}"; do
    wait_statefulset_pods_gone "${ns_list[$i]}" "${sts_list[$i]}"
  done

  echo "Exporting encrypted bundles to $output_dir (parallel) ..."
  local -a export_pids=()
  local -a export_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"

    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      export_bundle_from_pvc "$ns" "$sts" "$ordinal" "$output_dir" &
      export_pids+=("$!")
      export_descs+=("${ns}/${sts}/${ordinal}")
    done
  done

  local export_failed=0
  for i in "${!export_pids[@]}"; do
    if ! wait "${export_pids[$i]}"; then
      echo "Error: encrypted bundle export failed for ${export_descs[$i]}." >&2
      export_failed=1
    fi
  done
  if [[ "$export_failed" -ne 0 ]]; then
    echo "Error: one or more encrypted bundle exports failed." >&2
    return 1
  fi

  echo "Restoring TON StatefulSets replicas ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" "${replicas_list[$i]}"
  done
  if [[ "$operator_paused" -eq 1 ]]; then
    resume_operator_reconcile operator_deploy_names operator_deploy_replicas
    operator_paused=0
  fi

  restore_required=0
  trap - EXIT INT TERM
  echo "Encrypted key bundle backup complete: $output_dir"
}

run_restore_keys() {
  require_bin kubectl
  require_bin sha256sum

  if [[ $# -ne 1 ]]; then
    echo "Error: usage: kubeton restore-keys <input-dir>" >&2
    exit 1
  fi
  local input_dir="$1"
  if [[ ! -d "$input_dir" ]]; then
    echo "Error: restore input dir not found: $input_dir" >&2
    exit 1
  fi
  input_dir="$(cd "$input_dir" && pwd)"

  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  confirm_or_exit "This will overwrite encrypted key bundles from ${input_dir} and restart TON StatefulSets. Missing replica backups will be reported and skipped. Continue?"

  local -a ns_list=()
  local -a sts_list=()
  local -a replicas_list=()
  local -a operator_deploy_names=()
  local -a operator_deploy_replicas=()
  local row ns sts replicas i ordinal
  local operator_paused=0
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    replicas="${replicas:-0}"
    ns_list+=("$ns")
    sts_list+=("$sts")
    replicas_list+=("$replicas")
  done

  local restore_required=1
  cleanup_restore() {
    [[ "${restore_required:-0}" -ne 1 ]] && return 0
    local i
    for i in "${!sts_list[@]}"; do
      set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" "${replicas_list[$i]}" >/dev/null 2>&1 || true
    done
    if [[ "${operator_paused:-0}" -eq 1 ]]; then
      resume_operator_reconcile operator_deploy_names operator_deploy_replicas || true
    fi
  }
  trap cleanup_restore EXIT INT TERM

  pause_operator_reconcile operator_deploy_names operator_deploy_replicas
  operator_paused=1

  echo "Scaling TON StatefulSets to 0 ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" 0
  done
  for i in "${!sts_list[@]}"; do
    wait_statefulset_pods_gone "${ns_list[$i]}" "${sts_list[$i]}"
  done

  echo "Restoring encrypted bundles from $input_dir (parallel) ..."
  local restored_count=0
  local skipped_missing_count=0
  local failed_count=0
  local -a restore_pids=()
  local -a restore_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      restore_replica_from_backup "$ns" "$sts" "$ordinal" "$input_dir" &
      restore_pids+=("$!")
      restore_descs+=("${ns}/${sts}/${ordinal}")
    done
  done

  for i in "${!restore_pids[@]}"; do
    local restore_rc=0
    if wait "${restore_pids[$i]}"; then
      restore_rc=0
    else
      restore_rc=$?
    fi
    case "$restore_rc" in
      0)
        ((restored_count+=1))
        ;;
      10)
        ((skipped_missing_count+=1))
        ;;
      *)
        echo "Error: encrypted bundle restore failed for ${restore_descs[$i]}." >&2
        ((failed_count+=1))
        ;;
    esac
  done

  echo "Restoring TON StatefulSets replicas ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" "${replicas_list[$i]}"
  done
  if [[ "$operator_paused" -eq 1 ]]; then
    resume_operator_reconcile operator_deploy_names operator_deploy_replicas
    operator_paused=0
  fi

  restore_required=0
  trap - EXIT INT TERM
  echo "Restore summary: restored=${restored_count}, skipped_missing=${skipped_missing_count}, failed=${failed_count}"
  if (( restored_count == 0 )); then
    echo "Warning: no replica bundles were restored."
  fi
  echo "Encrypted key bundle restore complete. Pods will restore key material during startup."
}

run_stop_without_backup() {
  require_bin helm
  helm upgrade "$RELEASE_NAME" "$CHART_DIR" \
    -n "$OP_NAMESPACE" \
    -f "$OP_VALUES_FILE" \
    --set tonNode.enabled=false
}

run_stop_backup() {
  require_bin kubectl

  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found; skipping stop-time key backup."
    return 0
  fi

  echo "Triggering stop-time encrypted key backup in running TON pods ..."
  local -a failed_pods=()
  local row ns pod
  local skipped_count=0
  local backed_up_count=0
  local container_names=""
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod _ <<<"$row"

    container_names="$(kubectl -n "$ns" get pod "$pod" -o jsonpath='{.spec.containers[*].name}' 2>/dev/null || true)"
    if ! grep -qw "key-backup" <<<"$container_names"; then
      echo "Warning: ${ns}/${pod} has no key-backup sidecar; skipping stop-time backup." >&2
      ((skipped_count+=1))
      continue
    fi

    if trigger_key_backup_once "$ns" "$pod" && pod_has_encrypted_bundle "$ns" "$pod"; then
      ((backed_up_count+=1))
      continue
    fi
    echo "Error: ${ns}/${pod} did not produce encrypted bundle files after stop-time backup trigger." >&2
    failed_pods+=("${ns}/${pod}")
  done

  if [[ ${#failed_pods[@]} -gt 0 ]]; then
    echo "Error: stop-time key backup failed for: ${failed_pods[*]}" >&2
    echo "Refusing to stop TON pods to avoid losing in-memory keys." >&2
    echo "If you want to force stop anyway, run: SKIP_STOP_KEY_BACKUP=true ./kubeton stop" >&2
    return 1
  fi

  echo "Stop-time key backup summary: backed_up=${backed_up_count}, skipped=${skipped_count}"
}

run_stop() {
  if is_true "${SKIP_STOP_KEY_BACKUP:-false}"; then
    echo "SKIP_STOP_KEY_BACKUP=true, skipping stop-time key backup."
  else
    run_stop_backup
  fi
  run_stop_without_backup
}

run_drop() {
  require_bin helm
  require_bin kubectl
  confirm_or_exit "This will stop TON pods and DELETE TON PVC data. Continue?"
  run_stop_without_backup
  kubectl delete tonnodes.ton.ton.org --all -A --ignore-not-found
  kubectl delete pvc -A -l "$TON_POD_LABEL" --ignore-not-found
}

cleanup_longhorn_force() {
  echo "[uninstall] Forcing Longhorn cleanup ..."

  cleanup_longhorn_webhook_configs

  if kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    echo "[uninstall] Deleting Longhorn uninstall/install jobs ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete job longhorn-uninstall longhorn-install --ignore-not-found --wait=false >/dev/null 2>&1 || true
    echo "[uninstall] Deleting Longhorn namespaced workload resources ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete all --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  fi

  local resource
  for resource in $(kubectl api-resources --api-group=longhorn.io --namespaced=true -o name 2>/dev/null || true); do
    kubectl -n "$LONGHORN_NAMESPACE" get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl -n "$LONGHORN_NAMESPACE" patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    kubectl -n "$LONGHORN_NAMESPACE" delete "$resource" --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  for resource in $(kubectl api-resources --api-group=longhorn.io --namespaced=false -o name 2>/dev/null || true); do
    kubectl get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    kubectl delete "$resource" --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  kubectl get crd -o name 2>/dev/null \
    | grep 'longhorn.io' \
    | xargs -r -n1 kubectl delete --ignore-not-found --wait=false >/dev/null 2>&1 || true

  kubectl get crd -o name 2>/dev/null \
    | grep 'longhorn.io' \
    | xargs -r -I{} kubectl patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true

  if kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    echo "[uninstall] Removing Helm release metadata in ${LONGHORN_NAMESPACE} ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete secret,configmap -l "owner=helm,name=${LONGHORN_RELEASE_NAME}" --ignore-not-found >/dev/null 2>&1 || true
    force_finalize_namespace "$LONGHORN_NAMESPACE"
    wait_namespace_gone "$LONGHORN_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT" || true
  fi
}

uninstall_longhorn() {
  if ! helm status "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi
  echo "[uninstall] Running Helm uninstall for Longhorn release ${LONGHORN_RELEASE_NAME} ..."
  kubectl -n "$LONGHORN_NAMESPACE" patch settings.longhorn.io deleting-confirmation-flag --type=merge -p '{"value":"true"}' >/dev/null 2>&1 || true
  if helm uninstall "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE"; then
    return 0
  fi
  echo "Warning: Longhorn Helm uninstall failed; retrying with --no-hooks." >&2
  if helm uninstall "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE" --no-hooks >/dev/null 2>&1; then
    return 0
  fi
  echo "Warning: Longhorn Helm uninstall --no-hooks failed; running forced cleanup fallback." >&2
  cleanup_longhorn_force
}

uninstall_vault() {
  if ! helm status "$VAULT_RELEASE_NAME" -n "$VAULT_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi
  echo "[uninstall] Running Helm uninstall for Vault release ${VAULT_RELEASE_NAME} ..."
  if helm uninstall "$VAULT_RELEASE_NAME" -n "$VAULT_NAMESPACE"; then
    return 0
  fi
  echo "Warning: Vault Helm uninstall failed; retrying with --no-hooks." >&2
  if helm uninstall "$VAULT_RELEASE_NAME" -n "$VAULT_NAMESPACE" --no-hooks >/dev/null 2>&1; then
    return 0
  fi
  echo "Warning: Vault Helm uninstall --no-hooks failed; running forced cleanup fallback." >&2
  cleanup_vault_force
}

run_uninstall_core() {
  echo "[uninstall] Step 1/8: disabling TON resources in Helm release ${RELEASE_NAME} ..."
  run_stop_without_backup

  echo "[uninstall] Step 2/8: deleting TonNode custom resources ..."
  kubectl delete tonnodes.ton.ton.org --all -A --ignore-not-found

  echo "[uninstall] Step 3/8: deleting TON PVCs ..."
  kubectl delete pvc -A -l "$TON_POD_LABEL" --ignore-not-found

  echo "[uninstall] Step 4/8: uninstalling operator Helm release ${RELEASE_NAME} ..."
  helm uninstall "$RELEASE_NAME" -n "$OP_NAMESPACE" || true
  delete_namespace_with_progress "$OP_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 5/8: deleting StorageClass ${ENCRYPTED_SC_NAME} ..."
  kubectl delete storageclass "$ENCRYPTED_SC_NAME" --ignore-not-found >/dev/null 2>&1 || true

  echo "[uninstall] Step 6/8: uninstalling Longhorn release ${LONGHORN_RELEASE_NAME} ..."
  uninstall_longhorn || true
  cleanup_longhorn_force || true
  delete_namespace_with_progress "$LONGHORN_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 7/8: uninstalling Vault release ${VAULT_RELEASE_NAME} ..."
  uninstall_vault || true
  cleanup_vault_force || true
  delete_namespace_with_progress "$VAULT_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 8/8: uninstall core complete."
}

run_uninstall() {
  require_bin helm
  require_bin kubectl
  confirm_or_exit "WARNING: This will stop/delete TON pods and PVCs, uninstall operator, uninstall Longhorn release ${LONGHORN_RELEASE_NAME}, uninstall Vault release ${VAULT_RELEASE_NAME}, and delete StorageClass ${ENCRYPTED_SC_NAME}. TonNode CRD is kept. If Helm Longhorn uninstall hook fails, kubeton will run force-cleanup. Continue?"
  run_uninstall_core
}

run_purge() {
  require_bin helm
  require_bin kubectl
  confirm_or_exit "DANGER: purge runs full uninstall (operator + Longhorn + Vault + StorageClass cleanup) and also deletes CRD tonnodes.ton.ton.org (cluster-scoped). This is separated from uninstall to avoid accidental cluster-wide CRD removal. Continue?"
  run_uninstall_core
  echo "[purge] Deleting CRD tonnodes.ton.ton.org ..."
  kubectl delete crd tonnodes.ton.ton.org --ignore-not-found
  echo "[purge] Completed."
}

run_verify() {
  require_bin kubectl
  kubectl -n "$OP_NAMESPACE" get deploy,pods
  kubectl -n "$TON_NAMESPACE" get tonnodes
  kubectl -n "$TON_NAMESPACE" get sts,pods,pvc
}

run_status() {
  require_bin kubectl
  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found."
    return
  fi

  local -a table_rows=()
  local cell_db_size
  local archive_db_size
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod node_name <<<"$row"

    sync_output="$(sync_value "$ns" "$pod")"
    sync_output="${sync_output//$'\t'/ }"
    [[ -z "$node_name" ]] && node_name="N/A"
    cell_db_size="$(folder_size_gb "$ns" "$pod" "/var/ton-work/db/celldb")"
    archive_db_size="$(folder_size_gb "$ns" "$pod" "/var/ton-work/db/archive")"
    table_rows+=("$node_name"$'\t'"$pod"$'\t'"$sync_output"$'\t'"$cell_db_size"$'\t'"$archive_db_size")
  done

  print_aligned_table_5col "server name" "pod name" "sync" "cell db" "archive db" "${table_rows[@]}"
}

run_exec() {
  require_bin kubectl
  local cmd="${*:-}"
  if [[ -z "$cmd" ]]; then
    echo "Error: missing command for exec." >&2
    usage
    exit 1
  fi

  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found."
    return
  fi

  local -a table_rows=()
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod node_name <<<"$row"

    if kubectl -n "$ns" exec "$pod" -- bash -lc "$cmd" >/dev/null 2>&1; then
      exit_code=0
    else
      exit_code=$?
    fi
    [[ -z "$node_name" ]] && node_name="N/A"
    table_rows+=("$node_name"$'\t'"$pod"$'\t'"$exit_code")
  done

  print_aligned_table_3col "server name" "pod name" "exit code" "${table_rows[@]}"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    install)
      run_install
      ;;
    bootstrap-baremetal)
      run_bootstrap_baremetal
      ;;
    start)
      run_start "${1:-}"
      ;;
    add)
      run_add "$@"
      ;;
    del)
      run_del "$@"
      ;;
    upgrade)
      run_upgrade "$@"
      ;;
    backup-keys)
      run_backup_keys "${1:-}"
      ;;
    restore-keys)
      run_restore_keys "$@"
      ;;
    stop)
      run_stop
      ;;
    drop)
      run_drop
      ;;
    uninstall)
      run_uninstall
      ;;
    purge)
      run_purge
      ;;
    verify)
      run_verify
      ;;
    status)
      run_status
      ;;
    exec)
      run_exec "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Error: unknown command '$command'." >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
