cleanup_prometheus_port_forwards() {
  local state_dir="${PROMETHEUS_PORT_FORWARD_DIR}"
  local pid_file pid

  if [[ ! -d "$state_dir" ]]; then
    return 0
  fi

  for pid_file in "$state_dir"/*.pid; do
    [[ -f "$pid_file" ]] || continue
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]]; then
