  name: ${VICTORIA_METRICS_STATE_CONFIGMAP}
  labels:
    app.kubernetes.io/name: kubeton-victoria-metrics
    app.kubernetes.io/managed-by: kubeton
    app.kubernetes.io/part-of: kubeton-victoria-metrics
data:
  stackName: $(yaml_quote "$stack_name")
  stackNamespace: $(yaml_quote "$stack_namespace")
  operatorNamespace: $(yaml_quote "$operator_namespace")
  operatorVersion: $(yaml_quote "$operator_version")
  operatorManifestUrl: $(yaml_quote "$operator_manifest_url")
EOF
}

ensure_victoria_metrics_operator() {
  local operator_ns="$1"
  local stack_name="$2"
  local version manifest_url timeout_seconds

  version="$(resolve_victoria_metrics_operator_version)" || return 1
  manifest_url="$(victoria_metrics_operator_manifest_url "$version")"
  timeout_seconds="$(resolve_victoria_metrics_rollout_timeout_seconds)"

  echo "[victoria-metrics] Installing/updating VictoriaMetrics operator (${version}) ..." >&2
  if ! kubectl apply -f "$manifest_url" >/dev/null; then
    echo "Error: failed to apply VictoriaMetrics operator manifest ${manifest_url}." >&2
    return 1
  fi

  if ! kubectl -n "$operator_ns" rollout status "deployment/${VICTORIA_METRICS_OPERATOR_DEPLOYMENT}" --timeout="${timeout_seconds}s" >/dev/null 2>&1; then
    echo "Warning: VictoriaMetrics operator deployment ${operator_ns}/${VICTORIA_METRICS_OPERATOR_DEPLOYMENT} is not Ready yet." >&2
  fi

  printf '%s\t%s\n' "$version" "$manifest_url"
}

wait_victoria_metrics_cr_operational() {
  local ns="$1"
  local kind="$2"
  local name="$3"
  local timeout_seconds="$4"

  if ! kubectl -n "$ns" wait --for=jsonpath='{.status.updateStatus}'=operational "${kind}/${name}" --timeout="${timeout_seconds}s" >/dev/null 2>&1; then
    echo "Warning: ${kind}/${name} in namespace ${ns} did not reach status.updateStatus=operational within ${timeout_seconds}s." >&2
  fi
}

ensure_victoria_metrics_stack() {
