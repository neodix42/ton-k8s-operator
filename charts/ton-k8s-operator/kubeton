  local index=0
  local url datasource_name is_default

  echo "apiVersion: 1"
  echo "datasources:"
  for row in "$@"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns service_name deploy_name exporter_address <<<"$row"
    ns="$(trim_whitespace "$ns")"
    service_name="$(trim_whitespace "$service_name")"
    if [[ -z "$ns" || -z "$service_name" ]]; then
      continue
    fi
    url="http://${service_name}.${ns}.svc:${PROMETHEUS_PORT}"
    datasource_name="kubeton-prometheus-${ns}-${service_name}"
    is_default="false"
    if (( index == 0 )); then
      is_default="true"
    fi
    echo "  - name: $(yaml_quote "$datasource_name")"
    echo "    type: prometheus"
    echo "    access: proxy"
    echo "    url: $(yaml_quote "$url")"
    echo "    isDefault: ${is_default}"
    echo "    editable: false"
    ((index+=1))
  done
}

