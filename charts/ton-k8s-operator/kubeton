  fi

  echo "[uninstall] Step 2/9: deleting TonNode custom resources ..."
  kubectl delete tonnodes.ton.ton.org --all -A --ignore-not-found

  echo "[uninstall] Step 3/9: deleting TON PVCs ..."
  kubectl delete pvc -A -l "$TON_POD_LABEL" --ignore-not-found
  delete_ton_pvcs_for_statefulsets uninstall_sts_rows

  echo "[uninstall] Step 4/9: deleting kubeton-managed Prometheus/Grafana/VictoriaMetrics resources and port-forwards ..."
  cleanup_prometheus_resources
  cleanup_grafana_resources
  cleanup_victoria_metrics_resources

  echo "[uninstall] Step 5/9: uninstalling operator Helm release ${RELEASE_NAME} ..."
  helm uninstall "$RELEASE_NAME" -n "$OP_NAMESPACE" || true
  delete_namespace_with_progress "$OP_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 6/9: deleting StorageClass ${ENCRYPTED_SC_NAME} ..."
  kubectl delete storageclass "$ENCRYPTED_SC_NAME" --ignore-not-found >/dev/null 2>&1 || true

  echo "[uninstall] Step 7/9: uninstalling Longhorn release ${LONGHORN_RELEASE_NAME} ..."
  uninstall_longhorn || true
  cleanup_longhorn_force || true
  delete_namespace_with_progress "$LONGHORN_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 8/9: uninstalling Vault release ${VAULT_RELEASE_NAME} ..."
  uninstall_vault || true
  cleanup_vault_force || true
  delete_namespace_with_progress "$VAULT_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT"

  echo "[uninstall] Step 9/9: uninstall core complete."
}

