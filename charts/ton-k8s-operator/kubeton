}

victoria_metrics_stack_name() {
  local stack_name
  stack_name="$(sanitize_k8s_name_fragment "${VICTORIA_METRICS_STACK_NAME:-kubeton}")"
  stack_name="$(trim_whitespace "$stack_name")"
  if [[ -z "$stack_name" ]]; then
    stack_name="kubeton"
  fi
  printf '%s' "$stack_name"
}

resolve_victoria_metrics_rollout_timeout_seconds() {
  local timeout_seconds
  timeout_seconds="$(trim_whitespace "${VICTORIA_METRICS_ROLLOUT_TIMEOUT_SECONDS:-300}")"
  if ! [[ "$timeout_seconds" =~ ^[0-9]+$ ]] || (( timeout_seconds < 60 )); then
    timeout_seconds=300
  fi
  printf '%s' "$timeout_seconds"
}

resolve_victoria_metrics_operator_version() {
  local configured version redirect_url

  configured="$(trim_whitespace "${VM_OPERATOR_VERSION:-}")"
  if [[ -n "$configured" ]]; then
    printf '%s' "$configured"
    return 0
  fi

  if ! command -v curl >/dev/null 2>&1; then
    echo "Error: VM_OPERATOR_VERSION is empty and curl is required to resolve VictoriaMetrics operator latest release." >&2
    return 1
  fi

  redirect_url="$(curl -fs -o /dev/null -w '%{redirect_url}' https://github.com/VictoriaMetrics/operator/releases/latest || true)"
  redirect_url="$(trim_whitespace "$redirect_url")"
  if [[ -z "$redirect_url" ]]; then
    redirect_url="$(curl -fsSL -o /dev/null -w '%{url_effective}' https://github.com/VictoriaMetrics/operator/releases/latest || true)"
    redirect_url="$(trim_whitespace "$redirect_url")"
  fi
  version="${redirect_url##*/}"
  version="$(trim_whitespace "$version")"
  if [[ -z "$version" || "$version" == "latest" ]]; then
    echo "Error: failed to resolve VictoriaMetrics operator latest release tag. Set VM_OPERATOR_VERSION explicitly." >&2
    return 1
  fi
  printf '%s' "$version"
}

victoria_metrics_operator_manifest_url() {
  local version="$1"
  printf '%s' "https://github.com/VictoriaMetrics/operator/releases/download/${version}/${VICTORIA_METRICS_OPERATOR_INSTALL_MANIFEST}"
}

read_victoria_metrics_state_value() {
  local ns="$1"
  local key="$2"

  kubectl -n "$ns" get configmap "$VICTORIA_METRICS_STATE_CONFIGMAP" \
    -o jsonpath="{.data.${key}}" 2>/dev/null \
    || true
}

write_victoria_metrics_state() {
  local state_ns="$1"
  local stack_name="$2"
  local stack_namespace="$3"
  local operator_namespace="$4"
  local operator_version="$5"
  local operator_manifest_url="$6"

  ensure_namespace "$state_ns"
  cat <<EOF | kubectl -n "$state_ns" apply -f - >/dev/null
