run_status() {
  require_bin kubectl
  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found."
    return
  fi

  local status_tmp_dir=""
  local -a table_rows=()
  local -a result_files=()
  local -a fallback_rows=()
  local -a pids=()
  local row ns pod node_name result_file
  local i

  status_tmp_dir="$(mktemp -d -t kubeton-status.XXXXXX)"
  for i in "${!pod_rows[@]}"; do
    row="${pod_rows[$i]}"
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod node_name <<<"$row"
    [[ -z "$node_name" ]] && node_name="N/A"
    result_file="${status_tmp_dir}/row-${i}.tsv"
    result_files[$i]="$result_file"
    fallback_rows[$i]="$node_name"$'\t'"$pod"$'\t'"N/A"$'\t'"N/A"$'\t'"N/A"$'\t'"N/A"$'\t'"N/A"$'\t'"N/A"$'\t'"N/A"
    status_collect_row "$ns" "$pod" "$node_name" "$result_file" &
    pids+=("$!")
  done

  for i in "${!pids[@]}"; do
    wait "${pids[$i]}" || true
  done

  for i in "${!pod_rows[@]}"; do
    result_file="${result_files[$i]:-}"
    if [[ -n "$result_file" && -s "$result_file" ]]; then
      table_rows+=("$(cat "$result_file")")
    else
      [[ -n "${fallback_rows[$i]:-}" ]] && table_rows+=("${fallback_rows[$i]}")
    fi
  done

  rm -rf "$status_tmp_dir" >/dev/null 2>&1 || true

  print_aligned_table_9col "server name" "pod name" "commit" "date" "wallet" "ADNL address" "sync" "cell db" "archive db" "${table_rows[@]}"
}

run_prometheus_start() {
  require_bin kubectl
  require_bin nohup
  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton prometheus start" >&2
    exit 1
  fi
  local -a access_rows=()
  local -a forwarded_rows=()
  local row ns service_name deploy_name exporter_address forward_row log_file
  local base_port local_port remote_port bind_address remote_access_host
  local i attempt quiet_attempt

  configure_prometheus_for_exporter_targets access_rows || true
  if [[ ${#access_rows[@]} -eq 0 ]]; then
    return 1
  fi

  remote_port="$PROMETHEUS_PORT"
  if ! [[ "$remote_port" =~ ^[0-9]+$ ]]; then
    remote_port=9090
  fi
  base_port="$PROMETHEUS_LOCAL_PORT_BASE"
  if ! [[ "$base_port" =~ ^[0-9]+$ ]]; then
    base_port=9090
  fi
  bind_address="$(prometheus_port_forward_address)"
  bind_address="$(trim_whitespace "$bind_address")"
  if [[ -z "$bind_address" ]]; then
    bind_address="127.0.0.1"
  fi

  echo "[metrics] Starting background local port-forward(s) ..."
  echo "[metrics] Port-forward bind address: ${bind_address}"
  for i in "${!access_rows[@]}"; do
    row="${access_rows[$i]}"
    IFS=$'\t' read -r ns service_name deploy_name exporter_address <<<"$row"
    local_port="$((base_port + i))"
    for ((attempt=0; attempt<25; attempt++)); do
      quiet_attempt="true"
      if (( attempt == 24 )); then
        quiet_attempt="false"
      fi
      if forward_row="$(ensure_prometheus_port_forward "$ns" "$service_name" "$((local_port + attempt))" "$remote_port" "$bind_address" "$quiet_attempt")"; then
        forwarded_rows+=("$forward_row")
        break
      fi
    done
  done

  if [[ ${#forwarded_rows[@]} -eq 0 ]]; then
    echo "Error: failed to start any background port-forward for Prometheus services." >&2
    return 1
  fi

  for row in "${forwarded_rows[@]}"; do
    IFS=$'\t' read -r ns service_name local_port _pid log_file <<<"$row"
    if address_list_allows_loopback "$bind_address"; then
      echo "[metrics] Background access: http://127.0.0.1:${local_port}/targets (service ${ns}/${service_name})"
    fi
    if address_list_exposes_non_loopback "$bind_address"; then
      remote_access_host="$(first_non_loopback_bind_address "$bind_address" || true)"
      remote_access_host="$(trim_whitespace "$remote_access_host")"
      if [[ -z "$remote_access_host" ]]; then
        remote_access_host="$(resolve_primary_host_address || true)"
        remote_access_host="$(trim_whitespace "$remote_access_host")"
      fi
      if [[ -n "$remote_access_host" ]]; then
        echo "[metrics] Remote access: http://${remote_access_host}:${local_port}/targets"
      fi
    fi
    echo "[metrics] Port-forward log: ${log_file}"
  done

  return 0
}

run_prometheus_stop() {
  require_bin kubectl
  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton prometheus stop" >&2
    exit 1
  fi

  cleanup_prometheus_resources
  echo "[metrics] kubeton-managed Prometheus resources and local port-forward(s) removed."
}

run_prometheus() {
  local subcommand="${1:-}"
  case "$subcommand" in
    start)
      shift
      run_prometheus_start "$@"
      ;;
    stop)
      shift
      run_prometheus_stop "$@"
      ;;
    "")
      echo "Error: usage: kubeton prometheus <start|stop>" >&2
      exit 1
      ;;
    *)
      echo "Error: unknown prometheus subcommand '$subcommand'." >&2
      echo "Usage: kubeton prometheus <start|stop>" >&2
      exit 1
      ;;
  esac
}

