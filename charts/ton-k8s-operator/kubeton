bytes_to_human() {
  local bytes="$1"
  if ! [[ "$bytes" =~ ^[0-9]+$ ]]; then
    echo "N/A"
    return
  fi
  awk -v b="$bytes" 'BEGIN {
    if (b < 1024) {
      printf "%.0f B", b
    } else if (b < 1024*1024) {
      printf "%.2f KB", b/1024
    } else if (b < 1024*1024*1024) {
      printf "%.2f MB", b/1024/1024
    } else if (b < 1024*1024*1024*1024) {
      printf "%.2f GB", b/1024/1024/1024
    } else {
      printf "%.2f TB", b/1024/1024/1024/1024
    }
  }'
}

folder_size_gb() {
  local ns="$1"
  local pod="$2"
  local folder="$3"
  local bytes=""

  bytes="$(run_with_timeout "$STATUS_EXEC_TIMEOUT" kubectl -n "$ns" exec "$pod" -- bash -lc "
    bytes=\$(du -s -B1 \"$folder\" 2>/dev/null | cut -f1 | head -n1)
    if [[ \"\$bytes\" =~ ^[0-9]+$ ]]; then
      printf '%s' \"\$bytes\"
      exit 0
    fi
    kbytes=\$(du -sk \"$folder\" 2>/dev/null | cut -f1 | head -n1)
    if [[ \"\$kbytes\" =~ ^[0-9]+$ ]]; then
      printf '%s' \$((kbytes*1024))
      exit 0
    fi
    exit 1
  " 2>/dev/null || true)"
  if [[ -n "$bytes" ]]; then
    bytes="${bytes%%$'\n'*}"
    bytes="$(printf '%s' "$bytes" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    bytes_to_human "$bytes"
    return
  fi

  echo "N/A"
}

sync_value() {
  local ns="$1"
  local pod="$2"
  local output=""

  output="$(run_with_timeout "$STATUS_EXEC_TIMEOUT" kubectl -n "$ns" exec "$pod" -- bash -lc 'shopt -s expand_aliases; if [[ -f ~/.bashrc ]]; then source ~/.bashrc >/dev/null 2>&1; fi; sync' 2>/dev/null || true)"
  output="${output//$'\r'/}"
  output="$(printf '%s' "$output" | sed -E $'s/\x1B\\[[0-9;]*[[:alpha:]]//g')"
  output="$(printf '%s\n' "$output" | awk 'NF{print; exit}')"
  output="$(printf '%s' "$output" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

  if [[ -z "$output" ]]; then
    echo "N/A"
    return
  fi

  echo "$output"
}

wallet_adnl_values() {
  local ns="$1"
  local pod="$2"
  local output=""
  local wallet=""
  local adnl=""

  output="$(run_with_timeout "$STATUS_EXEC_TIMEOUT" kubectl -n "$ns" exec "$pod" -- bash -lc '
    shopt -s expand_aliases
    if [[ -f ~/.bashrc ]]; then
      source ~/.bashrc >/dev/null 2>&1
    fi
    if command -v mytonctrl >/dev/null 2>&1; then
      echo status fast | mytonctrl
    fi
  ' 2>/dev/null || true)"
  output="${output//$'\r'/}"
  output="$(printf '%s' "$output" | sed -E $'s/\x1B\\[[0-9;]*[[:alpha:]]//g')"
  wallet="$(printf '%s\n' "$output" | awk -F': ' '/^Local validator wallet address:/ {print $2; exit}')"
  wallet="$(trim_whitespace "$wallet")"
  adnl="$(printf '%s\n' "$output" | awk -F': ' '/^Public ADNL address of node:/ {print $2; exit}')"
  adnl="$(trim_whitespace "$adnl")"

  if [[ -z "$wallet" ]]; then
    wallet="N/A"
  fi
  if [[ -z "$adnl" ]]; then
    adnl="N/A"
  fi
  printf '%s\t%s\n' "$wallet" "$adnl"
}

validator_build_values() {
  local ns="$1"
  local pod="$2"
  local output=""
  local commit=""
  local build_date=""

  output="$(run_with_timeout "$STATUS_EXEC_TIMEOUT" kubectl -n "$ns" exec "$pod" -- bash -lc '
    if [[ -x /usr/bin/ton/validator-engine/validator-engine ]]; then
      /usr/bin/ton/validator-engine/validator-engine -V 2>/dev/null | head -n1
    elif command -v validator-engine >/dev/null 2>&1; then
      validator-engine -V 2>/dev/null | head -n1
    else
      true
    fi
  ' 2>/dev/null || true)"
  output="${output//$'\r'/}"
  output="$(printf '%s' "$output" | sed -E $'s/\x1B\\[[0-9;]*[[:alpha:]]//g')"
  output="$(trim_whitespace "$output")"

  if [[ -n "$output" ]]; then
    commit="$(printf '%s\n' "$output" | sed -n 's/.*Commit:[[:space:]]*\([0-9a-fA-F]\{7,\}\).*/\1/p' | head -n1)"
    build_date="$(printf '%s\n' "$output" | sed -n 's/.*Date:[[:space:]]*\([^]]*\)].*/\1/p' | head -n1)"
  fi

  commit="$(trim_whitespace "$commit")"
  build_date="$(trim_whitespace "$build_date")"
  if [[ -z "$commit" ]]; then
    commit="N/A"
  else
    commit="${commit:0:7}"
  fi
  if [[ -z "$build_date" ]]; then
    build_date="N/A"
  fi
  printf '%s\t%s\n' "$commit" "$build_date"
}

status_collect_row() {
  local ns="$1"
  local pod="$2"
  local node_name="$3"
  local out_file="$4"
  local wallet_adnl=""
  local validator_build=""
  local commit_output="N/A"
  local date_output="N/A"
  local wallet_output="N/A"
  local adnl_output="N/A"
  local sync_output
  local cell_db_size
  local archive_db_size

  wallet_adnl="$(wallet_adnl_values "$ns" "$pod")"
  if [[ -n "$wallet_adnl" ]]; then
    IFS=$'\t' read -r wallet_output adnl_output <<<"$wallet_adnl"
  fi
  validator_build="$(validator_build_values "$ns" "$pod")"
  if [[ -n "$validator_build" ]]; then
    IFS=$'\t' read -r commit_output date_output <<<"$validator_build"
  fi
  sync_output="$(sync_value "$ns" "$pod")"
  [[ -z "$node_name" ]] && node_name="N/A"
  cell_db_size="$(folder_size_gb "$ns" "$pod" "/var/ton-work/db/celldb")"
  archive_db_size="$(folder_size_gb "$ns" "$pod" "/var/ton-work/db/archive")"

  commit_output="${commit_output//$'\t'/ }"
  date_output="${date_output//$'\t'/ }"
  wallet_output="${wallet_output//$'\t'/ }"
  adnl_output="${adnl_output//$'\t'/ }"
  sync_output="${sync_output//$'\t'/ }"
  cell_db_size="${cell_db_size//$'\t'/ }"
  archive_db_size="${archive_db_size//$'\t'/ }"

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$node_name" "$pod" "$commit_output" "$date_output" "$wallet_output" "$adnl_output" "$sync_output" "$cell_db_size" "$archive_db_size" >"$out_file"
}

run_install() {
  require_bin helm
  local release_exists=0
  local -a helm_cmd=()

  if helm -n "$OP_NAMESPACE" status "$RELEASE_NAME" >/dev/null 2>&1; then
    release_exists=1
  fi

  helm_cmd=(
    helm upgrade --install "$RELEASE_NAME" "$CHART_DIR"
    -n "$OP_NAMESPACE"
    --create-namespace
    -f "$OP_VALUES_FILE"
  )

  if (( release_exists == 1 )); then
    # Preserve current TonNode chart values during operator-only upgrades.
    helm_cmd+=(--reuse-values)
    # If no TonNode CRs exist, keep operator-only behavior and avoid accidental TonNode recreation
    # from reused values.
    if ! cluster_has_tonnodes; then
      helm_cmd+=(--set tonNode.enabled=false)
    fi
  fi

  "${helm_cmd[@]}"
}

fleet_has_stop_annotations() {
  local -a sts_rows=()
  local row ns sts pause_annotation

  mapfile -t sts_rows < <(list_ton_statefulsets 2>/dev/null || true)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    return 1
  fi

  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts _ <<<"$row"
    [[ -z "$ns" || -z "$sts" ]] && continue

    pause_annotation="$(get_annotation_value statefulset "$ns" "$sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
    if [[ "$pause_annotation" =~ ^[0-9]+$ ]]; then
      return 0
    fi

    if kubectl -n "$ns" get tonnodes.ton.ton.org "$sts" >/dev/null 2>&1; then
      pause_annotation="$(get_annotation_value tonnodes.ton.ton.org "$ns" "$sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
      if [[ "$pause_annotation" =~ ^[0-9]+$ ]]; then
        return 0
      fi
    fi
  done

  return 1
}

run_bootstrap_baremetal() {
  require_bin kubectl
  require_bin helm
  if ! cluster_is_baremetal && ! cluster_is_k3d && ! is_true "$FORCE_BAREMETAL_BOOTSTRAP"; then
    echo "Cluster looks like cloud/managed (not bare-metal/local k3d)."
    echo "Use FORCE_BAREMETAL_BOOTSTRAP=true if you really want to bootstrap Longhorn+Vault here."
    exit 1
  fi
  ensure_auto_bootstrap_stack
  echo "[bootstrap] Completed."
}

run_start() {
  require_bin helm
  require_bin kubectl

  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton start" >&2
    exit 1
  fi

  local desired_replicas_for_start=""
  local restore_from_stop_metadata=0
  local -a extra_overrides=()
  local ton_selector_values_file=""
  local -a helm_cmd=()
  local helm_rc=0

  desired_replicas_for_start="$(resolve_ton_replicas_from_values_file "$TON_VALUES_FILE" || true)"
  if ! [[ "$desired_replicas_for_start" =~ ^[1-9][0-9]*$ ]]; then
    desired_replicas_for_start="$(resolve_ton_replicas_from_values_file "$CHART_DIR/values.yaml" || true)"
  fi
  if [[ "$desired_replicas_for_start" =~ ^[1-9][0-9]*$ ]]; then
    KUBETON_TARGET_TON_REPLICAS="$desired_replicas_for_start"
  fi

  if fleet_has_stop_annotations; then
    restore_from_stop_metadata=1
    echo "[start] Detected stopped TON fleet metadata; applying chart update before restoring previous replicas."
  fi

  if should_bootstrap_baremetal; then
    ensure_auto_bootstrap_stack
    append_baremetal_key_overrides extra_overrides
    if ! cluster_is_k3d && [[ -n "${LONGHORN_NODE_SELECTOR:-}" ]]; then
      ton_selector_values_file="$(build_ton_node_selector_values_file "$LONGHORN_NODE_SELECTOR")"
      extra_overrides+=(-f "$ton_selector_values_file")
    fi
  else
    validate_external_key_prereqs
  fi

  helm_cmd=(
    helm upgrade "$RELEASE_NAME" "$CHART_DIR"
    -n "$OP_NAMESPACE"
    -f "$OP_VALUES_FILE"
    -f "$TON_VALUES_FILE"
  )

  helm_cmd+=("${extra_overrides[@]}")

  "${helm_cmd[@]}" || helm_rc=$?

  if [[ -n "$ton_selector_values_file" ]]; then
    rm -f "$ton_selector_values_file" >/dev/null 2>&1 || true
  fi
  if (( helm_rc != 0 )); then
    return "$helm_rc"
  fi
  if (( restore_from_stop_metadata == 1 )); then
    run_start_stopped_fleet
  fi
}

run_backup_keys() {
  require_bin kubectl
  require_bin sha256sum
  require_bin date

  local default_output_root
  default_output_root="$(cd "$CHART_DIR/.." && pwd)/key-backups"
  local output_dir="${1:-$default_output_root/$(date -u +%Y%m%dT%H%M%SZ)}"
  if [[ $# -gt 1 ]]; then
    echo "Error: usage: kubeton backup-keys [output-dir]" >&2
    exit 1
  fi

  local -a sts_rows=()
  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  confirm_or_exit "This will trigger encrypted backup in each TON pod, scale StatefulSets to 0, export bundles, then scale back. Continue?"
  mkdir -p "$output_dir"

  local -a ns_list=()
  local -a sts_list=()
  local -a replicas_list=()
  local -A ordinal_node_maps=()
  local -A helper_nodes_by_replica=()
  local -a operator_deploy_names=()
  local -a operator_deploy_replicas=()
  local row ns sts replicas i ordinal pod node_map_key node_map
  local operator_paused=0
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    replicas="$(trim_whitespace "${replicas:-0}")"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    ns_list+=("$ns")
    sts_list+=("$sts")
    replicas_list+=("$replicas")
    if (( replicas > 0 )); then
      node_map_key="${ns}/${sts}"
      node_map="$(build_sts_ordinal_node_map "$ns" "$sts" "$replicas" || true)"
      node_map="$(trim_whitespace "$node_map")"
      if [[ -n "$node_map" ]]; then
        ordinal_node_maps["$node_map_key"]="$node_map"
      fi
    fi
  done

  local restore_required=1
  cleanup_restore() {
    [[ "${restore_required:-0}" -ne 1 ]] && return 0
    local i ns sts replicas node_map_key node_map
    local -a expected_nodes=()
    for i in "${!sts_list[@]}"; do
      ns="${ns_list[$i]}"
      sts="${sts_list[$i]}"
      replicas="${replicas_list[$i]}"
      if [[ "$replicas" =~ ^[1-9][0-9]*$ ]]; then
        node_map_key="${ns}/${sts}"
        node_map="${ordinal_node_maps[$node_map_key]:-}"
        expected_nodes=()
        if [[ -n "$node_map" ]] \
          && parse_ordinal_node_map "$node_map" expected_nodes \
          && (( ${#expected_nodes[@]} >= replicas )) \
          && restore_statefulset_with_expected_nodes "$ns" "$sts" "$replicas" expected_nodes >/dev/null 2>&1; then
          continue
        fi
      fi
      set_ton_replicas "$ns" "$sts" "$replicas" >/dev/null 2>&1 || true
    done
    if [[ "${operator_paused:-0}" -eq 1 ]]; then
      resume_operator_reconcile operator_deploy_names operator_deploy_replicas || true
    fi
  }
  trap cleanup_restore EXIT INT TERM

  echo "Triggering manual encrypted bundle backup in each TON pod (parallel) ..."
  local -a trigger_pids=()
  local -a trigger_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      pod="${sts}-${ordinal}"
      local helper_key="${ns}/${sts}/${ordinal}"
      local pod_node=""
      pod_node="$(kubectl -n "$ns" get pod "$pod" -o jsonpath='{.spec.nodeName}' 2>/dev/null || true)"
      pod_node="$(trim_whitespace "$pod_node")"
      if [[ -n "$pod_node" ]]; then
        helper_nodes_by_replica["$helper_key"]="$pod_node"
      fi
      trigger_key_backup_once "$ns" "$pod" &
      trigger_pids+=("$!")
      trigger_descs+=("${ns}/${pod}")
    done
  done

  local trigger_failed=0
  for i in "${!trigger_pids[@]}"; do
    if ! wait "${trigger_pids[$i]}"; then
      echo "Error: key backup trigger failed for ${trigger_descs[$i]}." >&2
      trigger_failed=1
    fi
  done
  if [[ "$trigger_failed" -ne 0 ]]; then
    echo "Error: one or more pod backup triggers failed." >&2
    return 1
  fi

  pause_operator_reconcile operator_deploy_names operator_deploy_replicas
  operator_paused=1

  echo "Scaling TON StatefulSets to 0 ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" 0
  done
  for i in "${!sts_list[@]}"; do
    wait_statefulset_pods_gone "${ns_list[$i]}" "${sts_list[$i]}"
  done

  echo "Exporting encrypted bundles to $output_dir (parallel) ..."
  local -a export_pids=()
  local -a export_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"

    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      local helper_key="${ns}/${sts}/${ordinal}"
      local helper_node="${helper_nodes_by_replica[$helper_key]:-}"
      export_bundle_from_pvc "$ns" "$sts" "$ordinal" "$output_dir" "$helper_node" &
      export_pids+=("$!")
      export_descs+=("${ns}/${sts}/${ordinal}")
    done
  done

  local export_failed=0
  for i in "${!export_pids[@]}"; do
    if ! wait "${export_pids[$i]}"; then
      echo "Error: encrypted bundle export failed for ${export_descs[$i]}." >&2
      export_failed=1
    fi
  done
  if [[ "$export_failed" -ne 0 ]]; then
    echo "Error: one or more encrypted bundle exports failed." >&2
    return 1
  fi

  echo "Restoring TON StatefulSets replicas with sticky node placement ..."
  local sticky_restore_count=0
  local sticky_restore_failed=0
  local -a expected_nodes=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      set_ton_replicas "$ns" "$sts" 0
      continue
    fi

    node_map_key="${ns}/${sts}"
    node_map="${ordinal_node_maps[$node_map_key]:-}"
    if [[ -z "$node_map" ]]; then
      echo "Error: missing pre-backup ordinal->node map for ${ns}/${sts}; refusing non-sticky restore." >&2
      ((sticky_restore_failed+=1))
      continue
    fi

    expected_nodes=()
    if ! parse_ordinal_node_map "$node_map" expected_nodes; then
      echo "Error: invalid pre-backup ordinal->node map for ${ns}/${sts}; refusing non-sticky restore." >&2
      ((sticky_restore_failed+=1))
      continue
    fi
    if (( ${#expected_nodes[@]} < replicas )); then
      echo "Error: incomplete pre-backup ordinal->node map for ${ns}/${sts} (have ${#expected_nodes[@]}, need ${replicas})." >&2
      ((sticky_restore_failed+=1))
      continue
    fi
    if restore_statefulset_with_expected_nodes "$ns" "$sts" "$replicas" expected_nodes; then
      ((sticky_restore_count+=1))
    else
      echo "Error: failed sticky-node restore for ${ns}/${sts} after backup." >&2
      ((sticky_restore_failed+=1))
    fi
  done
  echo "Backup node placement summary: restored=${sticky_restore_count}, failed=${sticky_restore_failed}"
  if (( sticky_restore_failed > 0 )); then
    return 1
  fi
  if [[ "$operator_paused" -eq 1 ]]; then
    resume_operator_reconcile operator_deploy_names operator_deploy_replicas
    operator_paused=0
  fi

  restore_required=0
  trap - EXIT INT TERM
  echo "Encrypted key bundle backup complete: $output_dir"
}

run_restore_keys() {
  require_bin kubectl
  require_bin sha256sum

  if [[ $# -ne 1 ]]; then
    echo "Error: usage: kubeton restore-keys <input-dir>" >&2
    exit 1
  fi
  local input_dir="$1"
  if [[ ! -d "$input_dir" ]]; then
    echo "Error: restore input dir not found: $input_dir" >&2
    exit 1
  fi
  input_dir="$(cd "$input_dir" && pwd)"

  local -a sts_rows=()
  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  confirm_or_exit "This will overwrite encrypted key bundles from ${input_dir} and restart TON StatefulSets. Missing replica backups will be reported and skipped. Continue?"

  local -a ns_list=()
  local -a sts_list=()
  local -a replicas_list=()
  local -A ordinal_node_maps=()
  local -A helper_nodes_by_replica=()
  local -a operator_deploy_names=()
  local -a operator_deploy_replicas=()
  local row ns sts replicas i ordinal node_map_key node_map
  local operator_paused=0
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    replicas="$(trim_whitespace "${replicas:-0}")"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    ns_list+=("$ns")
    sts_list+=("$sts")
    replicas_list+=("$replicas")
    if (( replicas > 0 )); then
      node_map_key="${ns}/${sts}"
      node_map="$(build_sts_ordinal_node_map "$ns" "$sts" "$replicas" || true)"
      node_map="$(trim_whitespace "$node_map")"
      if [[ -n "$node_map" ]]; then
        ordinal_node_maps["$node_map_key"]="$node_map"
      fi
    fi
  done

  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      local pod="${sts}-${ordinal}"
      local helper_key="${ns}/${sts}/${ordinal}"
      local pod_node=""
      pod_node="$(kubectl -n "$ns" get pod "$pod" -o jsonpath='{.spec.nodeName}' 2>/dev/null || true)"
      pod_node="$(trim_whitespace "$pod_node")"
      if [[ -n "$pod_node" ]]; then
        helper_nodes_by_replica["$helper_key"]="$pod_node"
      fi
    done
  done

  local restore_required=1
  cleanup_restore() {
    [[ "${restore_required:-0}" -ne 1 ]] && return 0
    local i ns sts replicas node_map_key node_map
    local -a expected_nodes=()
    for i in "${!sts_list[@]}"; do
      ns="${ns_list[$i]}"
      sts="${sts_list[$i]}"
      replicas="${replicas_list[$i]}"
      if [[ "$replicas" =~ ^[1-9][0-9]*$ ]]; then
        node_map_key="${ns}/${sts}"
        node_map="${ordinal_node_maps[$node_map_key]:-}"
        expected_nodes=()
        if [[ -n "$node_map" ]] \
          && parse_ordinal_node_map "$node_map" expected_nodes \
          && (( ${#expected_nodes[@]} >= replicas )) \
          && restore_statefulset_with_expected_nodes "$ns" "$sts" "$replicas" expected_nodes >/dev/null 2>&1; then
          continue
        fi
      fi
      set_ton_replicas "$ns" "$sts" "$replicas" >/dev/null 2>&1 || true
    done
    if [[ "${operator_paused:-0}" -eq 1 ]]; then
      resume_operator_reconcile operator_deploy_names operator_deploy_replicas || true
    fi
  }
  trap cleanup_restore EXIT INT TERM

  pause_operator_reconcile operator_deploy_names operator_deploy_replicas
  operator_paused=1

  echo "Scaling TON StatefulSets to 0 ..."
  for i in "${!sts_list[@]}"; do
    set_ton_replicas "${ns_list[$i]}" "${sts_list[$i]}" 0
  done
  for i in "${!sts_list[@]}"; do
    wait_statefulset_pods_gone "${ns_list[$i]}" "${sts_list[$i]}"
  done

  echo "Restoring encrypted bundles from $input_dir (parallel) ..."
  local restored_count=0
  local skipped_missing_count=0
  local failed_count=0
  local -a restore_pids=()
  local -a restore_descs=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      continue
    fi

    for ordinal in $(seq 0 $((replicas - 1))); do
      local helper_key="${ns}/${sts}/${ordinal}"
      local helper_node="${helper_nodes_by_replica[$helper_key]:-}"
      restore_replica_from_backup "$ns" "$sts" "$ordinal" "$input_dir" "$helper_node" &
      restore_pids+=("$!")
      restore_descs+=("${ns}/${sts}/${ordinal}")
    done
  done

  for i in "${!restore_pids[@]}"; do
    local restore_rc=0
    if wait "${restore_pids[$i]}"; then
      restore_rc=0
    else
      restore_rc=$?
    fi
    case "$restore_rc" in
      0)
        ((restored_count+=1))
        ;;
      10)
        ((skipped_missing_count+=1))
        ;;
      *)
        echo "Error: encrypted bundle restore failed for ${restore_descs[$i]}." >&2
        ((failed_count+=1))
        ;;
    esac
  done

  echo "Restoring TON StatefulSets replicas with sticky node placement ..."
  local sticky_restore_count=0
  local sticky_restore_failed=0
  local -a expected_nodes=()
  for i in "${!sts_list[@]}"; do
    ns="${ns_list[$i]}"
    sts="${sts_list[$i]}"
    replicas="${replicas_list[$i]}"
    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    if (( replicas == 0 )); then
      set_ton_replicas "$ns" "$sts" 0
      continue
    fi

    node_map_key="${ns}/${sts}"
    node_map="${ordinal_node_maps[$node_map_key]:-}"
    if [[ -z "$node_map" ]]; then
      echo "Error: missing pre-restore ordinal->node map for ${ns}/${sts}; refusing non-sticky restore." >&2
      ((sticky_restore_failed+=1))
      continue
    fi

    expected_nodes=()
    if ! parse_ordinal_node_map "$node_map" expected_nodes; then
      echo "Error: invalid pre-restore ordinal->node map for ${ns}/${sts}; refusing non-sticky restore." >&2
      ((sticky_restore_failed+=1))
      continue
    fi
    if (( ${#expected_nodes[@]} < replicas )); then
      echo "Error: incomplete pre-restore ordinal->node map for ${ns}/${sts} (have ${#expected_nodes[@]}, need ${replicas})." >&2
      ((sticky_restore_failed+=1))
      continue
    fi
    if restore_statefulset_with_expected_nodes "$ns" "$sts" "$replicas" expected_nodes; then
      ((sticky_restore_count+=1))
    else
      echo "Error: failed sticky-node restore for ${ns}/${sts} after restore-keys." >&2
      ((sticky_restore_failed+=1))
    fi
  done
  echo "Restore node placement summary: restored=${sticky_restore_count}, failed=${sticky_restore_failed}"
  if (( sticky_restore_failed > 0 )); then
    return 1
  fi
  if [[ "$operator_paused" -eq 1 ]]; then
    resume_operator_reconcile operator_deploy_names operator_deploy_replicas
    operator_paused=0
  fi

  restore_required=0
  trap - EXIT INT TERM
  echo "Restore summary: restored=${restored_count}, skipped_missing=${skipped_missing_count}, failed=${failed_count}"
  if (( restored_count == 0 )); then
    echo "Warning: no replica bundles were restored."
  fi
  echo "Encrypted key bundle restore complete. Pods will restore key material during startup."
}

run_stop_without_backup() {
  require_bin helm
  helm upgrade "$RELEASE_NAME" "$CHART_DIR" \
    -n "$OP_NAMESPACE" \
    -f "$OP_VALUES_FILE" \
    --set tonNode.enabled=false
}

run_stop_backup() {
  require_bin kubectl

  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found; skipping stop-time key backup."
    return 0
  fi

  echo "Triggering stop-time encrypted key backup in running TON pods ..."
  local -a failed_pods=()
  local row ns pod
  local skipped_count=0
  local backed_up_count=0
  local container_names=""
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod _ <<<"$row"

    container_names="$(kubectl -n "$ns" get pod "$pod" -o jsonpath='{.spec.containers[*].name}' 2>/dev/null || true)"
    if ! grep -qw "key-backup" <<<"$container_names"; then
      echo "Warning: ${ns}/${pod} has no key-backup sidecar; skipping stop-time backup." >&2
      ((skipped_count+=1))
      continue
    fi

    if trigger_key_backup_once "$ns" "$pod" && pod_has_encrypted_bundle "$ns" "$pod"; then
      ((backed_up_count+=1))
      continue
    fi
    echo "Error: ${ns}/${pod} did not produce encrypted bundle files after stop-time backup trigger." >&2
    failed_pods+=("${ns}/${pod}")
  done

  if [[ ${#failed_pods[@]} -gt 0 ]]; then
    echo "Error: stop-time key backup failed for: ${failed_pods[*]}" >&2
    echo "Refusing to stop TON pods to avoid losing in-memory keys." >&2
    echo "If you want to force pod stop anyway, run: SKIP_STOP_KEY_BACKUP=true ./kubeton stop" >&2
    echo "Or disable TON via Helm directly: helm upgrade $RELEASE_NAME $CHART_DIR -n $OP_NAMESPACE -f $OP_VALUES_FILE --set tonNode.enabled=false" >&2
    return 1
  fi

  echo "Stop-time key backup summary: backed_up=${backed_up_count}, skipped=${skipped_count}"
}

run_stop() {
  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton stop" >&2
    exit 1
  fi
  run_stop_fleet
}

run_stop_fleet() {
  require_bin kubectl
  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton stop" >&2
    exit 1
  fi

  if is_true "$SKIP_STOP_KEY_BACKUP"; then
    echo "SKIP_STOP_KEY_BACKUP=true, skipping stop-time key backup."
  else
    run_stop_backup
  fi

  local -a sts_rows=()
  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  local row ns sts replicas
  local pause_annotation existing_pause_annotation tonnode_exists
  local node_map_annotation node_map_patch
  local tonnodes_paused=0
  local fallback_statefulsets_scaled=0

  echo "Stopping TON fleet by setting TonNode replicas to 0 (operator stays running) ..."
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts replicas <<<"$row"
    if [[ -z "$ns" || -z "$sts" ]]; then
      continue
    fi

    if ! [[ "$replicas" =~ ^[0-9]+$ ]]; then
      replicas=0
    fi
    node_map_annotation="$(build_sts_ordinal_node_map "$ns" "$sts" "$replicas" || true)"
    node_map_annotation="$(trim_whitespace "$node_map_annotation")"
    node_map_patch="\"${KUBETON_PAUSE_NODEMAP_ANNOTATION_KEY}\":null"
    if [[ -n "$node_map_annotation" ]]; then
      node_map_patch="\"${KUBETON_PAUSE_NODEMAP_ANNOTATION_KEY}\":\"${node_map_annotation}\""
    fi

    tonnode_exists=0
    if kubectl -n "$ns" get tonnodes.ton.ton.org "$sts" >/dev/null 2>&1; then
      tonnode_exists=1
      existing_pause_annotation="$(get_annotation_value tonnodes.ton.ton.org "$ns" "$sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
    else
      existing_pause_annotation="$(get_annotation_value statefulset "$ns" "$sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
    fi
    if [[ "$existing_pause_annotation" =~ ^[1-9][0-9]*$ ]]; then
      pause_annotation="$existing_pause_annotation"
    else
      pause_annotation="$replicas"
    fi

    if (( tonnode_exists == 1 )); then
      kubectl -n "$ns" patch tonnodes.ton.ton.org "$sts" --type=merge \
        -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":\"${pause_annotation}\",${node_map_patch}}}}" >/dev/null
      ((tonnodes_paused+=1))
      kubectl -n "$ns" patch statefulset "$sts" --type=merge \
        -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":\"${pause_annotation}\",${node_map_patch}}}}" >/dev/null 2>&1 || true
    else
      echo "Warning: TonNode ${ns}/${sts} not found; using StatefulSet scale fallback." >&2
      kubectl -n "$ns" patch statefulset "$sts" --type=merge \
        -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":\"${pause_annotation}\",${node_map_patch}}}}" >/dev/null 2>&1 || true
      set_ton_replicas "$ns" "$sts" 0
      ((fallback_statefulsets_scaled+=1))
    fi
  done

  echo "Waiting for TON pods to terminate ..."
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns sts _ <<<"$row"
    [[ -z "$ns" || -z "$sts" ]] && continue
    wait_statefulset_pods_gone "$ns" "$sts"
  done

  echo "Stop summary: tonnodes_stopped=${tonnodes_paused}, fallback_statefulsets_scaled=${fallback_statefulsets_scaled}, operator_scaled_to_zero=0"
}

run_start_stopped_fleet() {
  require_bin kubectl
  if [[ $# -ne 0 ]]; then
    echo "Error: internal usage: run_start_stopped_fleet does not accept arguments" >&2
    exit 1
  fi

  local target_replicas pause_annotation
  local tonnode_spec_replicas
  local fallback_replicas
  local -a sts_rows=()
  local row row_ns row_sts row_replicas
  local resumed_tonnodes=0
  local resumed_statefulsets=0
  local skipped=0
  local paused_without_annotation=0

  mapfile -t sts_rows < <(list_ton_statefulsets)
  if [[ ${#sts_rows[@]} -eq 0 || -z "${sts_rows[0]}" ]]; then
    echo "No TON StatefulSets found."
    return
  fi

  echo "Restoring TON fleet from stop annotations ..."
  for row in "${sts_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r row_ns row_sts row_replicas <<<"$row"
    if [[ -z "$row_ns" || -z "$row_sts" ]]; then
      continue
    fi
    if ! [[ "$row_replicas" =~ ^[0-9]+$ ]]; then
      row_replicas=0
    fi

    target_replicas=""
    if kubectl -n "$row_ns" get tonnodes.ton.ton.org "$row_sts" >/dev/null 2>&1; then
      tonnode_spec_replicas="$(kubectl -n "$row_ns" get tonnodes.ton.ton.org "$row_sts" -o jsonpath='{.spec.replicas}' 2>/dev/null || true)"
      pause_annotation="$(get_annotation_value tonnodes.ton.ton.org "$row_ns" "$row_sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
      if [[ "$pause_annotation" =~ ^[0-9]+$ ]]; then
        if (( pause_annotation > row_replicas )); then
          target_replicas="$pause_annotation"
          kubectl -n "$row_ns" patch tonnodes.ton.ton.org "$row_sts" --type=merge \
            -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":null}},\"spec\":{\"replicas\":${target_replicas}}}" >/dev/null
          ((resumed_tonnodes+=1))
        elif (( row_replicas == 0 )) && [[ "$tonnode_spec_replicas" =~ ^[1-9][0-9]*$ ]]; then
          target_replicas="$tonnode_spec_replicas"
          echo "Warning: ${KUBETON_PAUSE_ANNOTATION_KEY}=${pause_annotation} on TonNode ${row_ns}/${row_sts}; restoring using TonNode spec.replicas=${target_replicas}."
          kubectl -n "$row_ns" patch tonnodes.ton.ton.org "$row_sts" --type=merge \
            -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":null}},\"spec\":{\"replicas\":${target_replicas}}}" >/dev/null 2>&1 || true
          ((resumed_tonnodes+=1))
        else
          kubectl -n "$row_ns" patch tonnodes.ton.ton.org "$row_sts" --type=merge \
            -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":null}}}" >/dev/null 2>&1 || true
          ((skipped+=1))
        fi
      else
        if [[ "$tonnode_spec_replicas" =~ ^[1-9][0-9]*$ ]] && (( tonnode_spec_replicas > row_replicas )); then
          target_replicas="$tonnode_spec_replicas"
          echo "Warning: missing ${KUBETON_PAUSE_ANNOTATION_KEY} on TonNode ${row_ns}/${row_sts}; restoring from TonNode spec.replicas=${target_replicas}."
          kubectl -n "$row_ns" patch tonnodes.ton.ton.org "$row_sts" --type=merge \
            -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":null}},\"spec\":{\"replicas\":${target_replicas}}}" >/dev/null 2>&1 || true
          ((resumed_tonnodes+=1))
        else
          if (( row_replicas == 0 )); then
            ((paused_without_annotation+=1))
          fi
          ((skipped+=1))
        fi
      fi
      continue
    fi

    pause_annotation="$(get_annotation_value statefulset "$row_ns" "$row_sts" "$KUBETON_PAUSE_ANNOTATION_KEY")"
    if [[ "$pause_annotation" =~ ^[0-9]+$ ]]; then
      if (( pause_annotation > row_replicas )); then
        target_replicas="$pause_annotation"
        set_ton_replicas "$row_ns" "$row_sts" "$target_replicas"
        ((resumed_statefulsets+=1))
      elif (( row_replicas == 0 )); then
        fallback_replicas="$(resolve_ton_replicas_from_values_file "$TON_VALUES_FILE" || true)"
        if ! [[ "$fallback_replicas" =~ ^[1-9][0-9]*$ ]]; then
          fallback_replicas="$(resolve_ton_replicas_from_values_file "$CHART_DIR/values.yaml" || true)"
        fi
        if [[ "$fallback_replicas" =~ ^[1-9][0-9]*$ ]]; then
          echo "Warning: ${KUBETON_PAUSE_ANNOTATION_KEY}=${pause_annotation} on StatefulSet ${row_ns}/${row_sts}; restoring using values replicas=${fallback_replicas}."
          set_ton_replicas "$row_ns" "$row_sts" "$fallback_replicas"
          ((resumed_statefulsets+=1))
        else
          ((skipped+=1))
        fi
      else
        ((skipped+=1))
      fi
      kubectl -n "$row_ns" patch statefulset "$row_sts" --type=merge -p "{\"metadata\":{\"annotations\":{\"${KUBETON_PAUSE_ANNOTATION_KEY}\":null}}}" >/dev/null 2>&1 || true
    else
      fallback_replicas="$(resolve_ton_replicas_from_values_file "$TON_VALUES_FILE" || true)"
      if ! [[ "$fallback_replicas" =~ ^[1-9][0-9]*$ ]]; then
        fallback_replicas="$(resolve_ton_replicas_from_values_file "$CHART_DIR/values.yaml" || true)"
      fi

      if (( row_replicas == 0 )) && [[ "$fallback_replicas" =~ ^[1-9][0-9]*$ ]]; then
        echo "Warning: missing ${KUBETON_PAUSE_ANNOTATION_KEY} on StatefulSet ${row_ns}/${row_sts}; restoring using values replicas=${fallback_replicas}."
        set_ton_replicas "$row_ns" "$row_sts" "$fallback_replicas"
        ((resumed_statefulsets+=1))
      else
        if (( row_replicas == 0 )); then
          ((paused_without_annotation+=1))
        fi
        ((skipped+=1))
      fi
    fi
  done

  enforce_stopped_node_mappings_after_start || true

  echo "Start summary: tonnodes_restored=${resumed_tonnodes}, statefulsets_restored=${resumed_statefulsets}, skipped=${skipped}, operator_scaled_to_zero=0"
  if (( paused_without_annotation > 0 )); then
    echo "Warning: ${paused_without_annotation} StatefulSet(s) are at replicas=0 without ${KUBETON_PAUSE_ANNOTATION_KEY}; start could not infer target replicas." >&2
    echo "Patch TonNode replicas manually for these StatefulSets." >&2
  fi
}

run_drop() {
  require_bin helm
  require_bin kubectl
  local -a drop_sts_rows=()

  mapfile -t drop_sts_rows < <(list_ton_statefulsets 2>/dev/null || true)
  confirm_or_exit "This will stop TON pods and DELETE TON PVC data. Continue?"
  run_stop_without_backup
  kubectl delete tonnodes.ton.ton.org --all -A --ignore-not-found
  kubectl delete pvc -A -l "$TON_POD_LABEL" --ignore-not-found
  delete_ton_pvcs_for_statefulsets drop_sts_rows
}

cleanup_longhorn_force() {
  echo "[uninstall] Forcing Longhorn cleanup ..."

  cleanup_longhorn_webhook_configs

  if kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    echo "[uninstall] Deleting Longhorn uninstall/install jobs ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete job longhorn-uninstall longhorn-install --ignore-not-found --wait=false >/dev/null 2>&1 || true
    echo "[uninstall] Deleting Longhorn namespaced workload resources ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete all --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  fi

  local resource
  for resource in $(kubectl api-resources --api-group=longhorn.io --namespaced=true -o name 2>/dev/null || true); do
    kubectl -n "$LONGHORN_NAMESPACE" get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl -n "$LONGHORN_NAMESPACE" patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    kubectl -n "$LONGHORN_NAMESPACE" delete "$resource" --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  for resource in $(kubectl api-resources --api-group=longhorn.io --namespaced=false -o name 2>/dev/null || true); do
    kubectl get "$resource" -o name 2>/dev/null \
      | xargs -r -I{} kubectl patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true
    kubectl delete "$resource" --all --ignore-not-found --wait=false >/dev/null 2>&1 || true
  done

  kubectl get crd -o name 2>/dev/null \
    | grep 'longhorn.io' \
    | xargs -r -n1 kubectl delete --ignore-not-found --wait=false >/dev/null 2>&1 || true

  kubectl get crd -o name 2>/dev/null \
    | grep 'longhorn.io' \
    | xargs -r -I{} kubectl patch {} --type=merge -p '{"metadata":{"finalizers":[]}}' >/dev/null 2>&1 || true

  if kubectl get namespace "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    echo "[uninstall] Removing Helm release metadata in ${LONGHORN_NAMESPACE} ..."
    kubectl -n "$LONGHORN_NAMESPACE" delete secret,configmap -l "owner=helm,name=${LONGHORN_RELEASE_NAME}" --ignore-not-found >/dev/null 2>&1 || true
    force_finalize_namespace "$LONGHORN_NAMESPACE"
    wait_namespace_gone "$LONGHORN_NAMESPACE" "$NAMESPACE_DELETE_PROGRESS_TIMEOUT" || true
  fi
}

uninstall_longhorn() {
  local rc=0
  if ! helm status "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE" >/dev/null 2>&1; then
    return 0
  fi
  echo "[uninstall] Running Helm uninstall for Longhorn release ${LONGHORN_RELEASE_NAME} ..."
  kubectl -n "$LONGHORN_NAMESPACE" patch settings.longhorn.io deleting-confirmation-flag --type=merge -p '{"value":"true"}' >/dev/null 2>&1 || true
  if run_with_timeout "$HELM_UNINSTALL_CMD_TIMEOUT" helm uninstall "$LONGHORN_RELEASE_NAME" -n "$LONGHORN_NAMESPACE"; then
    return 0
  fi
  rc=$?
