  password="$(trim_whitespace "$password")"

  remote_port="$VICTORIA_METRICS_AUTH_PORT"
  if ! [[ "$remote_port" =~ ^[0-9]+$ ]]; then
    remote_port=8427
  fi
  base_port="$VICTORIA_METRICS_AUTH_LOCAL_PORT_BASE"
  if ! [[ "$base_port" =~ ^[0-9]+$ ]]; then
    base_port=8427
  fi
  api_proxy_base_port="$VICTORIA_METRICS_API_PROXY_LOCAL_PORT_BASE"
  if ! [[ "$api_proxy_base_port" =~ ^[0-9]+$ ]]; then
    api_proxy_base_port=18427
  fi
  bind_address="$(victoria_metrics_port_forward_address)"
  bind_address="$(trim_whitespace "$bind_address")"
  if [[ -z "$bind_address" ]]; then
    bind_address="127.0.0.1"
  fi

  echo "[victoria-metrics] Starting background local port-forward ..."
  echo "[victoria-metrics] Port-forward bind address: ${bind_address}"
  if forward_row="$(start_victoria_metrics_auth_port_forward "$ns" "$auth_service_name" "$base_port" "$remote_port" "$bind_address" || true)"; then
    forward_row="$(trim_whitespace "$forward_row")"
    if [[ -n "$forward_row" ]]; then
      forwarded_rows+=("$forward_row")
    fi
  fi

  if [[ ${#forwarded_rows[@]} -eq 0 ]]; then
    if kubectl -n "$ns" get deployment "$auth_deploy_name" >/dev/null 2>&1; then
      echo "Warning: failed to start port-forward for ${ns}/${auth_service_name}; restarting deployment ${auth_deploy_name} and retrying once ..." >&2
      kubectl -n "$ns" rollout restart "deployment/${auth_deploy_name}" >/dev/null 2>&1 || true
      kubectl -n "$ns" rollout status "deployment/${auth_deploy_name}" --timeout="${timeout_seconds}s" >/dev/null 2>&1 || true
      if forward_row="$(start_victoria_metrics_auth_port_forward "$ns" "$auth_service_name" "$base_port" "$remote_port" "$bind_address" || true)"; then
        forward_row="$(trim_whitespace "$forward_row")"
        if [[ -n "$forward_row" ]]; then
          forwarded_rows+=("$forward_row")
        fi
      fi
    fi
  fi

  if [[ ${#forwarded_rows[@]} -eq 0 ]]; then
    echo "Warning: failed to start background port-forward for VictoriaMetrics auth service ${ns}/${auth_service_name}." >&2
    echo "Warning: VictoriaMetrics stack is installed, but local VMAuth access is unavailable (kubelet proxy likely returned 502)." >&2
    echo "Warning: check node/kubelet reachability (kubectl get nodes -o wide) and retry: ./kubeton victoria-metrics install" >&2
    if api_proxy_row="$(ensure_victoria_metrics_api_proxy "$api_proxy_base_port" || true)"; then
      api_proxy_row="$(trim_whitespace "$api_proxy_row")"
      if [[ -n "$api_proxy_row" ]]; then
        IFS=$'\t' read -r api_proxy_port _api_proxy_pid api_proxy_log <<<"$api_proxy_row"
        api_proxy_port="$(trim_whitespace "$api_proxy_port")"
        api_proxy_log="$(trim_whitespace "$api_proxy_log")"
        if [[ -n "$api_proxy_port" ]]; then
          vmsingle_service="vmsingle-${stack_name}"
          vmagent_service="vmagent-${stack_name}"
          echo "[victoria-metrics] Local fallback VMUI (kubectl proxy): http://127.0.0.1:${api_proxy_port}/api/v1/namespaces/${ns}/services/http:${vmsingle_service}:8428/proxy/vmui/"
          echo "[victoria-metrics] Local fallback targets (kubectl proxy): http://127.0.0.1:${api_proxy_port}/api/v1/namespaces/${ns}/services/http:${vmagent_service}:8429/proxy/targets"
          echo "[victoria-metrics] Local fallback query (kubectl proxy): http://127.0.0.1:${api_proxy_port}/api/v1/namespaces/${ns}/services/http:${vmsingle_service}:8428/proxy/api/v1/query"
          if [[ -n "$api_proxy_log" ]]; then
            echo "[victoria-metrics] Local fallback proxy log: ${api_proxy_log}"
          fi
        fi
      fi
    fi
    ensure_victoria_metrics_nodeport_access "$ns" "$stack_name" "$remote_port" || true
    echo "[victoria-metrics] Username: ${username}"
    echo "[victoria-metrics] Password: ${password}"
    echo "[victoria-metrics] Credentials secret: ${ns}/${credentials_secret}"
    echo "[victoria-metrics] In-cluster VMAuth URL (pod/cluster only): http://${auth_service_name}.${ns}.svc:${remote_port}/"
    echo "[victoria-metrics] In-cluster query endpoint (pod/cluster only): http://${auth_service_name}.${ns}.svc:${remote_port}/api/v1/query"
    echo "[victoria-metrics] Operator namespace: ${operator_ns}"
    echo "[victoria-metrics] Operator version: ${operator_version}"
    echo "[victoria-metrics] Operator manifest: ${operator_manifest_url}"
    echo "[victoria-metrics] TonNode scrape resources configured: ${#scrape_rows[@]}"
    return 0
  fi

  IFS=$'\t' read -r pf_ns pf_service local_port _pid log_file <<<"${forwarded_rows[0]}"
  if address_list_allows_loopback "$bind_address"; then
    echo "[victoria-metrics] Background VMUI access: http://127.0.0.1:${local_port}/vmui/"
    echo "[victoria-metrics] Background targets access: http://127.0.0.1:${local_port}/targets"
  fi
  if address_list_exposes_non_loopback "$bind_address"; then
    remote_access_host="$(first_non_loopback_bind_address "$bind_address" || true)"
    remote_access_host="$(trim_whitespace "$remote_access_host")"
    if [[ -z "$remote_access_host" ]]; then
      remote_access_host="$(resolve_primary_host_address || true)"
      remote_access_host="$(trim_whitespace "$remote_access_host")"
    fi
    if [[ -n "$remote_access_host" ]]; then
      echo "[victoria-metrics] Remote VMUI access: http://${remote_access_host}:${local_port}/vmui/"
      echo "[victoria-metrics] Remote targets access: http://${remote_access_host}:${local_port}/targets"
    fi
  fi
  echo "[victoria-metrics] Username: ${username}"
  echo "[victoria-metrics] Password: ${password}"
  echo "[victoria-metrics] Credentials secret: ${ns}/${credentials_secret}"
  echo "[victoria-metrics] Operator namespace: ${operator_ns}"
  echo "[victoria-metrics] Operator version: ${operator_version}"
  echo "[victoria-metrics] Operator manifest: ${operator_manifest_url}"
  echo "[victoria-metrics] Query endpoint: http://127.0.0.1:${local_port}/api/v1/query"
  echo "[victoria-metrics] Port-forward log: ${log_file}"
  echo "[victoria-metrics] TonNode scrape resources configured: ${#scrape_rows[@]}"
}

run_victoria_metrics_uninstall() {
  require_bin kubectl
  if [[ $# -ne 0 ]]; then
    echo "Error: usage: kubeton victoria-metrics uninstall" >&2
    exit 1
  fi

  cleanup_victoria_metrics_resources
  echo "[victoria-metrics] kubeton-managed VictoriaMetrics resources and local port-forward(s) removed."
}

run_victoria_metrics() {
  local subcommand="${1:-}"
  case "$subcommand" in
    install)
      shift
      run_victoria_metrics_install "$@"
      ;;
    uninstall)
      shift
      run_victoria_metrics_uninstall "$@"
      ;;
    "")
      echo "Error: usage: kubeton victoria-metrics <install|uninstall>" >&2
      exit 1
      ;;
    *)
      echo "Error: unknown victoria-metrics subcommand '$subcommand'." >&2
      echo "Usage: kubeton victoria-metrics <install|uninstall>" >&2
      exit 1
      ;;
  esac
}

run_exec() {
  require_bin kubectl
  local cmd="${*:-}"
  if [[ -z "$cmd" ]]; then
    echo "Error: missing command for exec." >&2
    usage
    exit 1
  fi

  mapfile -t pod_rows < <(list_ton_pods)
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    echo "No TON pods found."
    return
  fi

  local -a table_rows=()
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns pod node_name <<<"$row"

    if kubectl -n "$ns" exec "$pod" -- bash -lc "$cmd" >/dev/null 2>&1; then
      exit_code=0
    else
      exit_code=$?
    fi
    [[ -z "$node_name" ]] && node_name="N/A"
    table_rows+=("$node_name"$'\t'"$pod"$'\t'"$exit_code")
  done

  print_aligned_table_3col "server name" "pod name" "exit code" "${table_rows[@]}"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    install)
      run_install
      ;;
    bootstrap-baremetal)
      run_bootstrap_baremetal
      ;;
    start)
      run_start "$@"
      ;;
    prometheus)
      run_prometheus "$@"
      ;;
    grafana)
      run_grafana "$@"
      ;;
    victoria-metrics)
      run_victoria_metrics "$@"
      ;;
    add)
      run_add "$@"
      ;;
    del)
      run_del "$@"
      ;;
    recreate)
      run_recreate "$@"
      ;;
    backup-keys)
      run_backup_keys "${1:-}"
      ;;
    restore-keys)
      run_restore_keys "$@"
      ;;
    stop)
      run_stop "$@"
      ;;
    drop)
      run_drop
      ;;
    uninstall)
      run_uninstall
      ;;
    purge)
      run_purge
      ;;
    verify)
      run_verify
      ;;
    status)
      run_status
      ;;
    exec)
      run_exec "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Error: unknown command '$command'." >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
