require_bin() {
  local bin="$1"
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "Error: required command not found: $bin" >&2
    exit 1
  fi
}

sanitize_compact() {
  # Keep printable token/key characters only and remove all control/whitespace noise.
  printf '%s' "${1:-}" | tr -d '\000-\037\177' | tr -d '[:space:]'
}

trim_whitespace() {
  printf '%s' "${1:-}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

run_with_timeout() {
  local timeout_value="$1"
  shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout_value" "$@"
    return $?
  fi
  "$@"
}

yaml_quote() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

json_quote() {
  local value="${1:-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  value="${value//$'\r'/}"
  value="${value//$'\t'/\\t}"
  printf '"%s"' "$value"
}

parse_selector_pairs() {
  local selector="$1"
  local -n out_pairs="$2"
  local -a tokens=()
  local token key value

  out_pairs=()
  selector="$(trim_whitespace "$selector")"
  [[ -z "$selector" ]] && return 0

  IFS=',' read -r -a tokens <<<"$selector"
  for token in "${tokens[@]}"; do
    token="$(trim_whitespace "$token")"
    [[ -z "$token" ]] && continue
    if [[ "$token" != *=* ]]; then
      echo "Error: invalid node selector token '${token}', expected key=value." >&2
      return 1
    fi
    key="$(trim_whitespace "${token%%=*}")"
    value="$(trim_whitespace "${token#*=}")"
    if [[ -z "$key" || -z "$value" ]]; then
      echo "Error: invalid node selector token '${token}', empty key or value." >&2
      return 1
    fi
    out_pairs+=("${key}=${value}")
  done
}

write_yaml_map_from_pairs() {
  local -n pairs_ref="$1"
  local indent="${2:-2}"
  local padding pair key value

  padding="$(printf '%*s' "$indent" '')"
  for pair in "${pairs_ref[@]}"; do
    key="${pair%%=*}"
    value="${pair#*=}"
    printf '%s%s: %s\n' "$padding" "$(yaml_quote "$key")" "$(yaml_quote "$value")"
  done
}

selector_pairs_to_longhorn_setting() {
  local -n pairs_ref="$1"
  local out="" pair key value

  for pair in "${pairs_ref[@]}"; do
    key="${pair%%=*}"
    value="${pair#*=}"
    [[ -n "$out" ]] && out+=";"
    out+="${key}:${value}"
  done
  printf '%s' "$out"
}

is_default_longhorn_node_selector() {
  local selector="$1"
  local -a selector_pairs=()

  parse_selector_pairs "$selector" selector_pairs || return 1
  [[ ${#selector_pairs[@]} -eq 1 && "${selector_pairs[0]}" == "node.longhorn.io/create-default-disk=true" ]]
}

desired_longhorn_node_count() {
  local desired="${KUBETON_TARGET_TON_REPLICAS:-}"
  if ! [[ "$desired" =~ ^[1-9][0-9]*$ ]]; then
    desired="${LONGHORN_DEFAULT_REPLICA_COUNT:-}"
  fi
  if ! [[ "$desired" =~ ^[1-9][0-9]*$ ]]; then
    desired="1"
  fi
  printf '%s' "$desired"
}

auto_label_default_longhorn_nodes() {
  local required_count="${1:-}"
  local -a target_nodes=()
  local -a matched_nodes=()
  local -A already_labeled=()
  local node
  local currently_labeled=0
  local labeled_now=0
  local max_count=0

  if ! [[ "$required_count" =~ ^[1-9][0-9]*$ ]]; then
    required_count="$(desired_longhorn_node_count)"
  fi

  mapfile -t matched_nodes < <(kubectl get nodes -l 'node.longhorn.io/create-default-disk=true' -o name 2>/dev/null | sed 's#^node/##' | awk 'NF' | sort)
  currently_labeled="${#matched_nodes[@]}"
  if (( currently_labeled >= required_count )); then
    return 0
  fi
  for node in "${matched_nodes[@]}"; do
    [[ -z "$node" ]] && continue
    already_labeled["$node"]=1
  done

  mapfile -t target_nodes < <(kubectl get nodes -l '!node-role.kubernetes.io/control-plane,!node-role.kubernetes.io/master' -o name 2>/dev/null | sed 's#^node/##' | awk 'NF' | sort)
  if [[ ${#target_nodes[@]} -eq 0 ]]; then
    mapfile -t target_nodes < <(kubectl get nodes -o name 2>/dev/null | sed 's#^node/##' | awk 'NF' | sort)
  fi

  if [[ ${#target_nodes[@]} -eq 0 ]]; then
    echo "Error: automatic labeling failed; no Kubernetes nodes found." >&2
    return 1
  fi

  max_count="${#target_nodes[@]}"
  if (( required_count > max_count )); then
    echo "Warning: requested ${required_count} Longhorn node(s) for default selector but only ${max_count} node(s) are available." >&2
    required_count="$max_count"
  fi

  echo "[baremetal] Ensuring default Longhorn label on ${required_count} node(s) ..."
  for node in "${target_nodes[@]}"; do
    [[ -z "$node" ]] && continue
    if [[ -n "${already_labeled[$node]:-}" ]]; then
      continue
    fi
    if (( currently_labeled + labeled_now >= required_count )); then
      break
    fi
    kubectl label node "$node" node.longhorn.io/create-default-disk=true --overwrite >/dev/null
    ((labeled_now+=1))
  done
}

build_ton_node_selector_values_file() {
  local selector="$1"
  local -a selector_pairs=()
  local values_file

  parse_selector_pairs "$selector" selector_pairs || return 1
  if [[ ${#selector_pairs[@]} -eq 0 ]]; then
    echo "Error: LONGHORN_NODE_SELECTOR is set but has no valid key=value pairs." >&2
    return 1
  fi

  values_file="$(mktemp -t kubeton-ton-selector.XXXXXX.yaml)"
  {
    echo "tonNode:"
    echo "  nodeSelector:"
    write_yaml_map_from_pairs selector_pairs 4
  } >"$values_file"

  printf '%s' "$values_file"
}

resolve_ton_replicas_from_values_file() {
  local values_file="$1"
  local replicas=""

  [[ -f "$values_file" ]] || return 1
  replicas="$(awk '
    /^[[:space:]]*tonNode:[[:space:]]*$/ {in_ton=1; next}
    in_ton && /^[^[:space:]]/ {in_ton=0}
    in_ton && /^[[:space:]]*replicas:[[:space:]]*[0-9]+([[:space:]]|$)/ {
      sub(/.*replicas:[[:space:]]*/, "", $0)
      sub(/[[:space:]]*#.*/, "", $0)
      sub(/[[:space:]].*/, "", $0)
      print $0
      exit
    }
  ' "$values_file" 2>/dev/null || true)"

  if [[ "$replicas" =~ ^[1-9][0-9]*$ ]]; then
    printf '%s' "$replicas"
    return 0
  fi
  return 1
}

cluster_has_tonnodes() {
  kubectl get tonnodes.ton.ton.org -A -o jsonpath='{range .items[*]}{.metadata.namespace}{"/"}{.metadata.name}{"\n"}{end}' 2>/dev/null \
    | awk 'NF {found=1; exit} END {exit(found ? 0 : 1)}'
}

resolve_tonnode_custom_parameters_rows() {
  kubectl get tonnodes.ton.ton.org -A \
    -o go-template='{{range .items}}{{ $ns := .metadata.namespace }}{{ $name := .metadata.name }}{{range .spec.env}}{{if eq .name "CUSTOM_PARAMETERS"}}{{$ns}}{{"\t"}}{{$name}}{{"\t"}}{{.value}}{{"\n"}}{{end}}{{end}}{{end}}'
}

extract_exporter_address() {
  local custom_parameters="$1"
  local exporter_address=""

  custom_parameters="$(trim_whitespace "$custom_parameters")"
  if [[ -z "$custom_parameters" ]]; then
    return 0
  fi

  if [[ "$custom_parameters" =~ (^|[[:space:]])--exporter-address=([^[:space:]]+) ]]; then
    exporter_address="${BASH_REMATCH[2]}"
  elif [[ "$custom_parameters" =~ (^|[[:space:]])--exporter-address[[:space:]]+([^[:space:]]+) ]]; then
    exporter_address="${BASH_REMATCH[2]}"
  fi

  exporter_address="$(trim_whitespace "$exporter_address")"
  exporter_address="${exporter_address#\"}"
  exporter_address="${exporter_address%\"}"
  exporter_address="${exporter_address#\'}"
  exporter_address="${exporter_address%\'}"
  printf '%s' "$exporter_address"
}

extract_exporter_port() {
  local exporter_address="$1"
  local port=""

  exporter_address="$(trim_whitespace "$exporter_address")"
  if [[ "$exporter_address" =~ :([0-9]{1,5})$ ]]; then
    port="${BASH_REMATCH[1]}"
  fi
  if [[ "$port" =~ ^[0-9]+$ ]] && (( port >= 1 && port <= 65535 )); then
    printf '%s' "$port"
  fi
}

normalize_prometheus_target_mode() {
  local raw mode
  raw="$(trim_whitespace "${PROMETHEUS_TARGET_MODE:-}")"
  mode="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"

  if [[ -z "$mode" || "$mode" == "auto" ]]; then
    if cluster_is_baremetal && ! cluster_is_k3d; then
      printf '%s' "external-nodeip"
    else
      printf '%s' "pod-ip"
    fi
    return 0
  fi

  case "$mode" in
    pod-ip|external-nodeip)
      printf '%s' "$mode"
      return 0
      ;;
    *)
      echo "Error: invalid PROMETHEUS_TARGET_MODE='${raw}'. Use one of: auto, pod-ip, external-nodeip." >&2
      return 1
      ;;
  esac
}

list_tonnode_running_pod_rows() {
  local ns="$1"
  local tonnode_name="$2"

  kubectl -n "$ns" get pods \
    -l "app.kubernetes.io/name=ton-node,app.kubernetes.io/instance=${tonnode_name}" \
    -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.metadata.name}{"\t"}{.status.podIP}{"\t"}{.spec.nodeName}{"\t"}{range .spec.containers[*]}{range .ports[*]}{.hostPort}{","}{end}{end}{"\n"}{end}' 2>/dev/null \
    | awk 'NF'
}

list_tonnode_running_pod_ips() {
  local ns="$1"
  local tonnode_name="$2"

  kubectl -n "$ns" get pods \
    -l "app.kubernetes.io/name=ton-node,app.kubernetes.io/instance=${tonnode_name}" \
    -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.status.podIP}{"\n"}{end}' 2>/dev/null \
    | awk 'NF' \
    | sort -u
}

list_node_external_ip_rows() {
  kubectl get nodes \
    -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{range .status.addresses[?(@.type=="ExternalIP")]}{.address}{" "}{end}{"\t"}{range .status.addresses[?(@.type=="InternalIP")]}{.address}{" "}{end}{"\n"}{end}' 2>/dev/null \
    | awk -F'\t' '
      NF {
        node=$1
        ext_ip=$2
        int_ip=$3
        sub(/^[[:space:]]+/, "", ext_ip)
        sub(/[[:space:]].*$/, "", ext_ip)
        sub(/^[[:space:]]+/, "", int_ip)
        sub(/[[:space:]].*$/, "", int_ip)
        if (node != "" && ext_ip != "") {
          print node "\t" ext_ip "\tExternalIP"
        } else if (node != "" && int_ip != "") {
          print node "\t" int_ip "\tInternalIP"
        }
      }
    '
}

host_port_list_contains() {
  local host_ports_csv="$1"
  local expected_port="$2"
  local token
  local -a host_ports=()

  IFS=',' read -r -a host_ports <<<"$host_ports_csv"
  for token in "${host_ports[@]}"; do
    token="$(trim_whitespace "$token")"
    [[ -z "$token" ]] && continue
    if [[ "$token" == "$expected_port" ]]; then
      return 0
    fi
  done
  return 1
}

trim_wrapped_quotes() {
  local value
  value="$(trim_whitespace "${1:-}")"
  value="${value#\"}"
  value="${value%\"}"
  value="${value#\'}"
  value="${value%\'}"
  printf '%s' "$value"
}

resolve_operator_image_from_values_file() {
  local values_file="$1"
  local repo=""
  local tag=""
  local in_image=0
  local line value

  [[ -f "$values_file" ]] || return 1

  while IFS= read -r line; do
    if [[ "$line" =~ ^image:[[:space:]]*$ ]]; then
      in_image=1
      continue
    fi
    if (( in_image != 0 )) && [[ "$line" =~ ^[^[:space:]] ]]; then
      break
    fi
    if (( in_image == 0 )); then
      continue
    fi

    if [[ "$line" =~ ^[[:space:]]*repository:[[:space:]]*(.+)$ ]]; then
      value="${BASH_REMATCH[1]}"
      value="${value%%#*}"
      repo="$(trim_wrapped_quotes "$value")"
      continue
    fi
    if [[ "$line" =~ ^[[:space:]]*tag:[[:space:]]*(.+)$ ]]; then
      value="${BASH_REMATCH[1]}"
      value="${value%%#*}"
      tag="$(trim_wrapped_quotes "$value")"
      continue
    fi
  done < "$values_file"

  repo="$(trim_whitespace "$repo")"
  tag="$(trim_whitespace "$tag")"
  [[ -z "$repo" ]] && return 1
  if [[ -n "$tag" ]]; then
    printf '%s:%s' "$repo" "$tag"
  else
    printf '%s' "$repo"
  fi
}

desired_operator_image() {
  local image
  image="$(resolve_operator_image_from_values_file "$OP_VALUES_FILE" || true)"
  image="$(trim_whitespace "$image")"
  if [[ -n "$image" ]]; then
    printf '%s' "$image"
    return 0
  fi

  image="$(resolve_operator_image_from_values_file "$CHART_DIR/values.yaml" || true)"
  image="$(trim_whitespace "$image")"
  if [[ -n "$image" ]]; then
    printf '%s' "$image"
    return 0
  fi
  return 1
}

current_operator_image() {
  kubectl -n "$OP_NAMESPACE" get deploy "$OP_CONTROLLER_DEPLOYMENT" \
    -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null \
    | awk 'NF {print; exit}'
}

ensure_external_nodeip_operator_support() {
  local timeout_seconds="${1:-420}"
  local desired_image current_image

  if ! is_true "$PROMETHEUS_EXTERNAL_NODEIP_OPERATOR_AUTOFIX"; then
    return 0
  fi

  desired_image="$(desired_operator_image || true)"
  desired_image="$(trim_whitespace "$desired_image")"
  current_image="$(current_operator_image || true)"
  current_image="$(trim_whitespace "$current_image")"

  if [[ -z "$desired_image" || -z "$current_image" || "$desired_image" == "$current_image" ]]; then
    return 0
  fi
  if ! command -v helm >/dev/null 2>&1; then
    echo "Warning: operator image is ${current_image}, chart expects ${desired_image}, but helm is not available for auto-upgrade." >&2
    return 1
  fi

  echo "[metrics] Detected operator image ${current_image}; upgrading to ${desired_image} ..."
  if ! run_install; then
    echo "Warning: failed to auto-upgrade operator release ${RELEASE_NAME}." >&2
    return 1
  fi
  if ! kubectl -n "$OP_NAMESPACE" rollout status "deployment/${OP_CONTROLLER_DEPLOYMENT}" --timeout="${timeout_seconds}s" >/dev/null 2>&1; then
    echo "Warning: operator deployment ${OP_NAMESPACE}/${OP_CONTROLLER_DEPLOYMENT} did not become Ready after auto-upgrade." >&2
    return 1
  fi

  current_image="$(current_operator_image || true)"
  current_image="$(trim_whitespace "$current_image")"
  if [[ -z "$current_image" || "$current_image" != "$desired_image" ]]; then
    echo "Warning: operator image is still '${current_image}' after auto-upgrade, expected '${desired_image}'." >&2
    return 1
  fi
  return 0
}

tonnode_host_ports_enabled() {
  local ns="$1"
  local tonnode_name="$2"
  local value=""

  value="$(kubectl -n "$ns" get tonnodes.ton.ton.org "$tonnode_name" -o jsonpath='{.spec.network.hostPortsEnabled}' 2>/dev/null || true)"
  value="$(trim_whitespace "$value")"
  if [[ -z "$value" || "$value" == "<no value>" ]]; then
    return 0
  fi
  is_true "$value"
}

enable_tonnode_host_ports() {
  local ns="$1"
  local tonnode_name="$2"

  if tonnode_host_ports_enabled "$ns" "$tonnode_name"; then
    return 1
  fi
  if ! kubectl -n "$ns" patch tonnodes.ton.ton.org "$tonnode_name" --type=merge \
    -p '{"spec":{"network":{"hostPortsEnabled":true}}}' >/dev/null 2>&1; then
    echo "Warning: failed to patch ${ns}/${tonnode_name} spec.network.hostPortsEnabled=true." >&2
    return 2
  fi
  echo "[metrics] Enabled spec.network.hostPortsEnabled=true for ${ns}/${tonnode_name} (required for external-nodeip targets)."
  return 0
}

list_statefulset_ton_container_port_rows() {
  local ns="$1"
  local tonnode_name="$2"

  kubectl -n "$ns" get statefulset "$tonnode_name" \
    -o jsonpath='{range .spec.template.spec.containers[?(@.name=="ton-node")].ports[*]}{.containerPort}{"\t"}{.hostPort}{"\n"}{end}' 2>/dev/null \
    | awk 'NF'
}

statefulset_exposes_exporter_hostport() {
  local ns="$1"
  local tonnode_name="$2"
  local exporter_port="$3"
  local row container_port host_port
  local -a port_rows=()

  mapfile -t port_rows < <(list_statefulset_ton_container_port_rows "$ns" "$tonnode_name")
  if [[ ${#port_rows[@]} -eq 0 || -z "${port_rows[0]}" ]]; then
    return 1
  fi

  for row in "${port_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r container_port host_port <<<"$row"
    container_port="$(trim_whitespace "$container_port")"
    host_port="$(trim_whitespace "$host_port")"
    if [[ "$container_port" == "$exporter_port" && "$host_port" == "$exporter_port" ]]; then
      return 0
    fi
  done
  return 1
}

all_tonnode_running_pods_expose_hostport() {
  local ns="$1"
  local tonnode_name="$2"
  local exporter_port="$3"
  local row pod_name _pod_ip _pod_node host_ports_csv
  local -a pod_rows=()

  mapfile -t pod_rows < <(list_tonnode_running_pod_rows "$ns" "$tonnode_name")
  if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
    return 1
  fi
  for row in "${pod_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r pod_name _pod_ip _pod_node host_ports_csv <<<"$row"
    if ! host_port_list_contains "$host_ports_csv" "$exporter_port"; then
      return 1
    fi
  done
  return 0
}

wait_statefulset_exporter_hostport() {
  local ns="$1"
  local tonnode_name="$2"
  local exporter_port="$3"
  local timeout_seconds="${4:-120}"
  local deadline now

  if ! [[ "$timeout_seconds" =~ ^[0-9]+$ ]]; then
    timeout_seconds=120
  fi
  deadline=$(( $(date +%s) + timeout_seconds ))
  while :; do
    if statefulset_exposes_exporter_hostport "$ns" "$tonnode_name" "$exporter_port"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 2
  done
}

ensure_external_nodeip_scrape_prereqs() {
  local ns="$1"
  local tonnode_name="$2"
  local exporter_port="$3"
  local timeout_seconds="${PROMETHEUS_EXTERNAL_NODEIP_AUTOFIX_TIMEOUT_SECONDS}"
  local wait_seconds
  local patch_status=1

  if ! [[ "$timeout_seconds" =~ ^[0-9]+$ ]] || (( timeout_seconds < 30 )); then
    timeout_seconds=420
  fi
  wait_seconds=$((timeout_seconds / 2))
  if (( wait_seconds < 30 )); then
    wait_seconds=30
  fi

  if all_tonnode_running_pods_expose_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    return 0
  fi

  if enable_tonnode_host_ports "$ns" "$tonnode_name"; then
    patch_status=0
  else
    patch_status=$?
  fi
  if (( patch_status == 2 )); then
    return 1
  fi

  if ! statefulset_exposes_exporter_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    ensure_external_nodeip_operator_support "$timeout_seconds" || true
  fi
  if (( patch_status == 1 )) && ! statefulset_exposes_exporter_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    echo "Warning: ${ns}/${tonnode_name} already has hostPortsEnabled=true but StatefulSet template still lacks exporter hostPort ${exporter_port}." >&2
    echo "Warning: this usually means the running ton-k8s-operator controller does not support exporter hostPort wiring yet; upgrade operator or use PROMETHEUS_TARGET_MODE=pod-ip." >&2
    return 1
  fi

  if ! statefulset_exposes_exporter_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    echo "[metrics] Waiting for StatefulSet ${ns}/${tonnode_name} template to expose exporter hostPort ${exporter_port} ..."
    if ! wait_statefulset_exporter_hostport "$ns" "$tonnode_name" "$exporter_port" "$wait_seconds"; then
      echo "Warning: StatefulSet ${ns}/${tonnode_name} template still does not expose exporter hostPort ${exporter_port}. Ensure ton-k8s-operator controller is upgraded." >&2
      return 1
    fi
  fi

  if all_tonnode_running_pods_expose_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    return 0
  fi

  echo "[metrics] Rolling restart StatefulSet ${ns}/${tonnode_name} to apply exporter hostPort ${exporter_port} ..."
  if ! kubectl -n "$ns" rollout restart "statefulset/${tonnode_name}" >/dev/null 2>&1; then
    echo "Warning: failed to rollout restart StatefulSet ${ns}/${tonnode_name}." >&2
    return 1
  fi
  if ! kubectl -n "$ns" rollout status "statefulset/${tonnode_name}" --timeout="${timeout_seconds}s" >/dev/null 2>&1; then
    echo "Warning: timeout waiting for StatefulSet ${ns}/${tonnode_name} rollout to complete." >&2
    return 1
  fi

  if ! all_tonnode_running_pods_expose_hostport "$ns" "$tonnode_name" "$exporter_port"; then
    echo "Warning: TON pods for ${ns}/${tonnode_name} are still missing hostPort ${exporter_port} after rollout." >&2
    return 1
  fi
  return 0
}

build_prometheus_static_targets_yaml() {
  local target

  for target in "$@"; do
    target="$(trim_whitespace "$target")"
    [[ -z "$target" ]] && continue
    printf '            - %s\n' "$(yaml_quote "$target")"
  done
}

sanitize_k8s_name_fragment() {
  local raw="${1:-}"
  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/-+/-/g; s/^-+//; s/-+$//')"
  if [[ -z "$raw" ]]; then
    raw="tonnode"
  fi
  printf '%s' "${raw:0:30}"
}

ensure_exporter_prometheus_stack() {
  local ns="$1"
  local tonnode_name="$2"
  local exporter_address="$3"
  local targets_yaml="$4"
  local name_suffix deploy_name service_name configmap_name

  name_suffix="$(sanitize_k8s_name_fragment "$tonnode_name")"
  deploy_name="kubeton-prometheus-${name_suffix}"
  service_name="${deploy_name}"
  configmap_name="${deploy_name}-config"

  cat <<EOF | kubectl -n "$ns" apply -f - >/dev/null
apiVersion: v1
kind: ConfigMap
metadata:
  name: ${configmap_name}
  labels:
    app.kubernetes.io/name: kubeton-prometheus
    app.kubernetes.io/instance: ${deploy_name}
    app.kubernetes.io/managed-by: kubeton
data:
  prometheus.yml: |
    global:
      scrape_interval: 15s
      evaluation_interval: 15s
    scrape_configs:
      - job_name: "ton-exporter-${name_suffix}"
        static_configs:
          - targets:
${targets_yaml}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${deploy_name}
  labels:
    app.kubernetes.io/name: kubeton-prometheus
    app.kubernetes.io/instance: ${deploy_name}
    app.kubernetes.io/managed-by: kubeton
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: kubeton-prometheus
      app.kubernetes.io/instance: ${deploy_name}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kubeton-prometheus
        app.kubernetes.io/instance: ${deploy_name}
      annotations:
        ton.ton.org/exporter-address: ${exporter_address}
    spec:
      containers:
        - name: prometheus
          image: ${PROMETHEUS_IMAGE}
          imagePullPolicy: IfNotPresent
          args:
            - --config.file=/etc/prometheus/prometheus.yml
            - --storage.tsdb.path=/prometheus
            - --web.listen-address=:${PROMETHEUS_PORT}
          ports:
            - name: http
              containerPort: ${PROMETHEUS_PORT}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /etc/prometheus
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 1Gi
      volumes:
        - name: config
          configMap:
            name: ${configmap_name}
---
apiVersion: v1
kind: Service
metadata:
  name: ${service_name}
  labels:
    app.kubernetes.io/name: kubeton-prometheus
    app.kubernetes.io/instance: ${deploy_name}
    app.kubernetes.io/managed-by: kubeton
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: kubeton-prometheus
    app.kubernetes.io/instance: ${deploy_name}
  ports:
    - name: http
      protocol: TCP
      port: ${PROMETHEUS_PORT}
      targetPort: http
EOF

  if ! kubectl -n "$ns" rollout status "deployment/${deploy_name}" --timeout=180s >/dev/null 2>&1; then
    echo "Warning: Prometheus deployment ${ns}/${deploy_name} is not Ready yet." >&2
  fi

  printf '%s\t%s\t%s\t%s\n' "$ns" "$service_name" "$deploy_name" "$exporter_address"
}

configure_prometheus_for_exporter_targets() {
  local output_rows_array_name="${1:-}"
  local -a custom_rows=()
  local -a configured_rows=()
  local row ns tonnode_name custom_parameters exporter_address exporter_port access_row service_name deploy_name
  local target_mode target_mode_desc
  local -a pod_ips=()
  local -a pod_rows=()
  local -a node_external_ip_rows=()
  local -a scrape_targets=()
  local scrape_targets_yaml=""
  local matched_count=0
  local i local_port
  local pod_row pod_name pod_ip pod_node_name host_ports_csv node_external_ip node_ip_source
  local target_resolution_failed
  local -A node_external_ip_by_name=()
  local -A node_ip_source_by_name=()

  if ! target_mode="$(normalize_prometheus_target_mode)"; then
    return 1
  fi
  if [[ "$target_mode" == "external-nodeip" ]]; then
    target_mode_desc="node ExternalIP/InternalIP targets"
    mapfile -t node_external_ip_rows < <(list_node_external_ip_rows)
    for row in "${node_external_ip_rows[@]}"; do
      [[ -z "$row" ]] && continue
      IFS=$'\t' read -r pod_node_name node_external_ip node_ip_source <<<"$row"
      pod_node_name="$(trim_whitespace "$pod_node_name")"
      node_external_ip="$(trim_whitespace "$node_external_ip")"
      node_ip_source="$(trim_whitespace "$node_ip_source")"
      [[ -z "$pod_node_name" || -z "$node_external_ip" ]] && continue
      node_external_ip_by_name["$pod_node_name"]="$node_external_ip"
      node_ip_source_by_name["$pod_node_name"]="$node_ip_source"
      if [[ "$node_ip_source" == "InternalIP" ]]; then
        echo "[metrics] Node ${pod_node_name} has no ExternalIP; using InternalIP ${node_external_ip} for scrape targets."
      fi
    done
  else
    target_mode_desc="TON pod IP targets"
  fi

  mapfile -t custom_rows < <(resolve_tonnode_custom_parameters_rows 2>/dev/null || true)

  for row in "${custom_rows[@]}"; do
    [[ -z "$row" ]] && continue
    IFS=$'\t' read -r ns tonnode_name custom_parameters <<<"$row"
    ns="$(trim_whitespace "$ns")"
    tonnode_name="$(trim_whitespace "$tonnode_name")"
    custom_parameters="$(trim_whitespace "$custom_parameters")"
    if [[ -z "$ns" || -z "$tonnode_name" || -z "$custom_parameters" || "$custom_parameters" == "<no value>" ]]; then
      continue
    fi

    exporter_address="$(extract_exporter_address "$custom_parameters")"
    if [[ -z "$exporter_address" ]]; then
      continue
    fi
    ((matched_count+=1))

    exporter_port="$(extract_exporter_port "$exporter_address")"
    if ! [[ "$exporter_port" =~ ^[0-9]+$ ]]; then
      echo "Warning: ignoring invalid --exporter-address '${exporter_address}' from TonNode ${ns}/${tonnode_name}." >&2
      continue
    fi

    if [[ "$target_mode" == "external-nodeip" ]] && is_true "$PROMETHEUS_EXTERNAL_NODEIP_AUTOFIX"; then
      ensure_external_nodeip_scrape_prereqs "$ns" "$tonnode_name" "$exporter_port" || true
    fi

    mapfile -t pod_rows < <(list_tonnode_running_pod_rows "$ns" "$tonnode_name")
    if [[ ${#pod_rows[@]} -eq 0 || -z "${pod_rows[0]}" ]]; then
      echo "Warning: no Running TON pods found for ${ns}/${tonnode_name}; Prometheus stack will not be created yet." >&2
      continue
    fi

    scrape_targets=()
    if [[ "$target_mode" == "external-nodeip" ]]; then
      target_resolution_failed=0
      for pod_row in "${pod_rows[@]}"; do
        [[ -z "$pod_row" ]] && continue
        IFS=$'\t' read -r pod_name pod_ip pod_node_name host_ports_csv <<<"$pod_row"
        pod_name="$(trim_whitespace "$pod_name")"
        pod_node_name="$(trim_whitespace "$pod_node_name")"
        if [[ -z "$pod_node_name" ]]; then
          echo "Warning: pod ${ns}/${pod_name} has no assigned node; cannot resolve node ExternalIP target." >&2
          target_resolution_failed=1
          continue
        fi
        if ! host_port_list_contains "$host_ports_csv" "$exporter_port"; then
          echo "Warning: pod ${ns}/${pod_name} does not expose hostPort ${exporter_port}; cannot use PROMETHEUS_TARGET_MODE=external-nodeip." >&2
          target_resolution_failed=1
          continue
        fi
        node_external_ip="$(trim_whitespace "${node_external_ip_by_name[$pod_node_name]:-}")"
        node_ip_source="$(trim_whitespace "${node_ip_source_by_name[$pod_node_name]:-}")"
        if [[ -z "$node_external_ip" ]]; then
          echo "Warning: node ${pod_node_name} has neither ExternalIP nor InternalIP; cannot use PROMETHEUS_TARGET_MODE=external-nodeip for pod ${ns}/${pod_name}." >&2
          target_resolution_failed=1
          continue
        fi
        [[ -z "$node_ip_source" ]] && node_ip_source="ExternalIP"
        scrape_targets+=("${node_external_ip}:${exporter_port}")
      done
      if (( target_resolution_failed != 0 )); then
        echo "Warning: failed to resolve external-nodeip scrape targets for ${ns}/${tonnode_name}; fix warnings above and retry." >&2
        continue
      fi
    else
      mapfile -t pod_ips < <(list_tonnode_running_pod_ips "$ns" "$tonnode_name")
      for i in "${!pod_ips[@]}"; do
        scrape_targets+=("${pod_ips[$i]}:${exporter_port}")
      done
    fi
    mapfile -t scrape_targets < <(printf '%s\n' "${scrape_targets[@]}" | awk 'NF' | sort -u)
    scrape_targets_yaml="$(build_prometheus_static_targets_yaml "${scrape_targets[@]}")"
    if [[ -z "$scrape_targets_yaml" ]]; then
      echo "Warning: failed to resolve scrape targets for ${ns}/${tonnode_name}." >&2
      continue
    fi

    if access_row="$(ensure_exporter_prometheus_stack "$ns" "$tonnode_name" "$exporter_address" "$scrape_targets_yaml")"; then
      configured_rows+=("$access_row")
    else
      echo "Error: failed to create Prometheus stack for TonNode ${ns}/${tonnode_name}." >&2
    fi
  done

  if [[ -n "$output_rows_array_name" ]]; then
    local -n output_rows_ref="$output_rows_array_name"
    output_rows_ref=("${configured_rows[@]}")
  fi

  if [[ ${#configured_rows[@]} -gt 0 ]]; then
    echo "[metrics] Prometheus stack is configured from CUSTOM_PARAMETERS exporter target(s)."
    for i in "${!configured_rows[@]}"; do
      row="${configured_rows[$i]}"
      IFS=$'\t' read -r ns service_name deploy_name exporter_address <<<"$row"
      local_port="$PROMETHEUS_LOCAL_PORT_BASE"
      if [[ "$PROMETHEUS_LOCAL_PORT_BASE" =~ ^[0-9]+$ ]]; then
        local_port="$((PROMETHEUS_LOCAL_PORT_BASE + i))"
      fi
      echo "[metrics] ${ns}/${deploy_name} configured from --exporter-address ${exporter_address} using ${target_mode_desc}."
    done
    return 0
  fi

  if (( matched_count == 0 )); then
    echo "No TonNode exporter targets found. Set TonNode env CUSTOM_PARAMETERS with --exporter-address <addr:port> first." >&2
  else
    echo "No Prometheus stacks were created. Ensure TON pods are Running and --exporter-address port is valid." >&2
  fi
  return 1
}

sanitize_file_name_fragment() {
  local raw="${1:-}"
  raw="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9._-]+/_/g')"
  if [[ -z "$raw" ]]; then
    raw="item"
  fi
  printf '%s' "$raw"
}

prometheus_port_forward_address() {
  local configured
  configured="$(trim_whitespace "${PROMETHEUS_PORT_FORWARD_ADDRESS:-}")"
  if [[ -n "$configured" ]]; then
    printf '%s' "$configured"
    return 0
  fi

  if cluster_is_baremetal && ! cluster_is_k3d; then
    printf '%s' "0.0.0.0"
    return 0
  fi

  printf '%s' "127.0.0.1"
}

is_loopback_host() {
  case "$(trim_whitespace "${1:-}")" in
    "" ) return 1 ;;
    localhost|127.0.0.1|::1) return 0 ;;
    *) return 1 ;;
  esac
}

address_list_exposes_non_loopback() {
  local raw="${1:-}"
  local token
  local -a addr_tokens=()
  IFS=',' read -r -a addr_tokens <<<"$raw"
  for token in "${addr_tokens[@]}"; do
    token="$(trim_whitespace "$token")"
    [[ -z "$token" ]] && continue
    if [[ "$token" == "0.0.0.0" || "$token" == "::" ]]; then
      return 0
    fi
    if ! is_loopback_host "$token"; then
      return 0
    fi
  done
  return 1
}

address_list_allows_loopback() {
  local raw="${1:-}"
  local token
  local -a addr_tokens=()
  IFS=',' read -r -a addr_tokens <<<"$raw"
  for token in "${addr_tokens[@]}"; do
    token="$(trim_whitespace "$token")"
