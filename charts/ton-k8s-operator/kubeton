  local row c1 c2 c3 c4 c5 c6 c7

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 c4 c5 c6 c7 <<<"$row"
    (( ${#c1} > w1 )) && w1=${#c1}
    (( ${#c2} > w2 )) && w2=${#c2}
    (( ${#c3} > w3 )) && w3=${#c3}
    (( ${#c4} > w4 )) && w4=${#c4}
    (( ${#c5} > w5 )) && w5=${#c5}
    (( ${#c6} > w6 )) && w6=${#c6}
    (( ${#c7} > w7 )) && w7=${#c7}
  done

  printf "| %-*s | %-*s | %-*s | %-*s | %-*s | %-*s | %-*s |\n" \
    "$w1" "$h1" "$w2" "$h2" "$w3" "$h3" "$w4" "$h4" "$w5" "$h5" "$w6" "$h6" "$w7" "$h7"
  printf "|-%s-|-%s-|-%s-|-%s-|-%s-|-%s-|-%s-|\n" \
    "$(dash_line "$w1")" "$(dash_line "$w2")" "$(dash_line "$w3")" "$(dash_line "$w4")" "$(dash_line "$w5")" "$(dash_line "$w6")" "$(dash_line "$w7")"
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r c1 c2 c3 c4 c5 c6 c7 <<<"$row"
    printf "| %-*s | %-*s | %-*s | %-*s | %-*s | %-*s | %-*s |\n" \
      "$w1" "$c1" "$w2" "$c2" "$w3" "$c3" "$w4" "$c4" "$w5" "$c5" "$w6" "$c6" "$w7" "$c7"
  done
}

