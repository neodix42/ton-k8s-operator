generate_random_password() {
  LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 24
}

ensure_grafana_admin_secret() {
  local ns="$1"
  local secret_name="$2"
  local admin_user="${GRAFANA_ADMIN_USER:-admin}"
  local admin_password="${GRAFANA_ADMIN_PASSWORD:-}"
  local existing_user existing_password

  admin_user="$(trim_whitespace "$admin_user")"
  if [[ -z "$admin_user" ]]; then
    admin_user="admin"
  fi

  if [[ -z "$admin_password" ]] && kubectl -n "$ns" get secret "$secret_name" >/dev/null 2>&1; then
    existing_user="$(kubectl -n "$ns" get secret "$secret_name" -o jsonpath='{.data.admin-user}' 2>/dev/null | base64 -d 2>/dev/null || true)"
    existing_password="$(kubectl -n "$ns" get secret "$secret_name" -o jsonpath='{.data.admin-password}' 2>/dev/null | base64 -d 2>/dev/null || true)"
    existing_user="$(trim_whitespace "$existing_user")"
    existing_password="$(trim_whitespace "$existing_password")"
    if [[ -n "$existing_user" && -n "$existing_password" ]]; then
      printf '%s\t%s\n' "$existing_user" "$existing_password"
      return 0
    fi
  fi

  if [[ -z "$admin_password" ]]; then
    admin_password="$(generate_random_password)"
  fi
  admin_password="$(trim_whitespace "$admin_password")"
  if [[ -z "$admin_password" ]]; then
    echo "Error: failed to resolve Grafana admin password." >&2
    return 1
  fi

  cat <<EOF | kubectl -n "$ns" apply -f - >/dev/null
apiVersion: v1
kind: Secret
metadata:
  name: ${secret_name}
  labels:
    app.kubernetes.io/name: kubeton-grafana
    app.kubernetes.io/managed-by: kubeton
type: Opaque
stringData:
  admin-user: $(yaml_quote "$admin_user")
  admin-password: $(yaml_quote "$admin_password")
EOF

  printf '%s\t%s\n' "$admin_user" "$admin_password"
}

build_grafana_datasources_yaml() {
