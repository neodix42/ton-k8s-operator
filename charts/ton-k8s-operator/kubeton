resolve_primary_host_address() {
  local candidate=""

  if command -v hostname >/dev/null 2>&1; then
    candidate="$(hostname -I 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i ~ /^[0-9.]+$/) {print $i; exit}}' || true)"
    candidate="$(trim_whitespace "$candidate")"
    if [[ -n "$candidate" ]]; then
      printf '%s' "$candidate"
      return 0
    fi

    candidate="$(hostname -f 2>/dev/null || true)"
    candidate="$(trim_whitespace "$candidate")"
    if [[ -n "$candidate" ]]; then
      printf '%s' "$candidate"
      return 0
    fi
  fi

  return 1
}

port_forward_process_matches() {
  local pid="$1"
  local ns="$2"
  local service_name="$3"
  local local_port="$4"
  local remote_port="$5"
  local bind_address="$6"
  local cmdline

  cmdline="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  [[ -z "$cmdline" ]] && return 1
  [[ "$cmdline" == *"kubectl"* ]] || return 1
  [[ "$cmdline" == *"port-forward"* ]] || return 1
  [[ "$cmdline" == *"svc/${service_name}"* ]] || return 1
  [[ "$cmdline" == *"${local_port}:${remote_port}"* ]] || return 1
  if [[ -n "$bind_address" && "$cmdline" != *"--address"* ]]; then
    return 1
  fi
  [[ "$cmdline" == *"-n ${ns}"* || "$cmdline" == *"--namespace ${ns}"* || "$cmdline" == *"--namespace=${ns}"* ]] || return 1
  return 0
}

wait_prometheus_http_ready() {
  local local_port="$1"
  local verify_seconds="$2"
  local deadline now

  if ! [[ "$verify_seconds" =~ ^[0-9]+$ ]]; then
    verify_seconds=20
  fi
  if (( verify_seconds <= 0 )); then
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    return 0
  fi

  deadline=$(( $(date +%s) + verify_seconds ))
  while :; do
    if curl -fsS --max-time 3 "http://127.0.0.1:${local_port}/-/ready" >/dev/null 2>&1 \
      || curl -fsS --max-time 3 "http://127.0.0.1:${local_port}/targets" >/dev/null 2>&1; then
      return 0
    fi

    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 1
  done
}

ensure_prometheus_port_forward() {
  local ns="$1"
  local service_name="$2"
  local local_port="$3"
  local remote_port="$4"
  local bind_address="${5:-127.0.0.1}"
  local quiet="${6:-false}"
  local state_dir="${PROMETHEUS_PORT_FORWARD_DIR}"
  local wait_seconds="${PROMETHEUS_PORT_FORWARD_WAIT_SECONDS}"
  local verify_seconds="${PROMETHEUS_PORT_FORWARD_VERIFY_SECONDS}"
  local key pid_file log_file existing_pid pf_pid deadline now

  if ! [[ "$local_port" =~ ^[0-9]+$ ]] || ! [[ "$remote_port" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  if ! [[ "$wait_seconds" =~ ^[0-9]+$ ]]; then
    wait_seconds=5
  fi
  if ! [[ "$verify_seconds" =~ ^[0-9]+$ ]]; then
    verify_seconds=20
  fi

  mkdir -p "$state_dir"
  key="$(sanitize_file_name_fragment "${ns}__${service_name}__${local_port}")"
  pid_file="${state_dir}/${key}.pid"
  log_file="${state_dir}/${key}.log"

  if [[ -f "$pid_file" ]]; then
    existing_pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ "$existing_pid" =~ ^[0-9]+$ ]] && kill -0 "$existing_pid" >/dev/null 2>&1; then
      if port_forward_process_matches "$existing_pid" "$ns" "$service_name" "$local_port" "$remote_port" "$bind_address"; then
        if wait_prometheus_http_ready "$local_port" 2; then
          printf '%s\t%s\t%s\t%s\t%s\n' "$ns" "$service_name" "$local_port" "$existing_pid" "$log_file"
          return 0
        fi
      fi
      kill "$existing_pid" >/dev/null 2>&1 || true
    fi
    rm -f "$pid_file" >/dev/null 2>&1 || true
  fi

  nohup kubectl -n "$ns" port-forward --address "$bind_address" "svc/${service_name}" "${local_port}:${remote_port}" >"$log_file" 2>&1 &
  pf_pid="$!"
  echo "$pf_pid" >"$pid_file"

  deadline=$(( $(date +%s) + wait_seconds ))
  while :; do
    if ! kill -0 "$pf_pid" >/dev/null 2>&1; then
      rm -f "$pid_file" >/dev/null 2>&1 || true
      if [[ "$quiet" != "1" && "$quiet" != "true" ]]; then
        echo "Warning: failed to start background port-forward for ${ns}/${service_name} on localhost:${local_port}." >&2
        echo "Warning: see ${log_file}" >&2
      fi
      return 1
    fi
    if grep -q "Forwarding from" "$log_file" 2>/dev/null; then
      if ! wait_prometheus_http_ready "$local_port" "$verify_seconds"; then
        kill "$pf_pid" >/dev/null 2>&1 || true
        rm -f "$pid_file" >/dev/null 2>&1 || true
        if [[ "$quiet" != "1" && "$quiet" != "true" ]]; then
          echo "Warning: port-forward for ${ns}/${service_name} started on localhost:${local_port}, but Prometheus HTTP endpoint is not ready." >&2
          echo "Warning: see ${log_file}" >&2
        fi
        return 1
      fi
      printf '%s\t%s\t%s\t%s\t%s\n' "$ns" "$service_name" "$local_port" "$pf_pid" "$log_file"
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      kill "$pf_pid" >/dev/null 2>&1 || true
      rm -f "$pid_file" >/dev/null 2>&1 || true
      if [[ "$quiet" != "1" && "$quiet" != "true" ]]; then
        echo "Warning: timed out waiting for port-forward readiness for ${ns}/${service_name} on localhost:${local_port}." >&2
        echo "Warning: see ${log_file}" >&2
      fi
      return 1
    fi
    sleep 1
  done
}

grafana_port_forward_address() {
